---
type SiteLanguage = "en" | "pt" | "es";

const currentPath = Astro.url.pathname;

const getRouteLanguage = (pathname: string): SiteLanguage => {
  if (pathname === "/pt" || pathname.startsWith("/pt/")) return "pt";
  if (pathname === "/es" || pathname.startsWith("/es/")) return "es";
  return "en";
};

const removeLanguagePrefix = (pathname: string): string => {
  if (pathname === "/pt" || pathname === "/es") return "/";

  return pathname.replace(/^\/(pt|es)(?=\/)/, "") || "/";
};

const getLocalizedPath = (language: SiteLanguage, pathname: string): string => {
  const cleanPath = removeLanguagePrefix(pathname);

  if (language === "en") {
    return cleanPath;
  }

  if (cleanPath === "/") {
    return `/${language}`;
  }

  return `/${language}${cleanPath}`;
};

const currentLanguage = getRouteLanguage(currentPath);

const languageOptions = {
  en: {
    flag: "🇺🇸",
    short: "EN",
    label: "English",
  },
  pt: {
    flag: "🇧🇷",
    short: "PT",
    label: "Português",
  },
  es: {
    flag: "🇪🇸",
    short: "ES",
    label: "Español",
  },
};

const text = {
  en: {
    about: "About",
    work: "Work",
    courses: "Courses",
    contact: "Contact",
    closeCourses: "Close courses modal",
    modalEyebrow: "COURSES BY GABRIEL SOARES",
    modalTitle: "The sound behind the records is becoming a course.",
    modalParagraphOne:
      "I’m preparing a premium learning experience for musicians, producers and acoustic guitarists who want to understand how professional recordings are really built.",
    modalParagraphTwo:
      "Acoustic guitar tone, production decisions, arrangements, workflow, taste and the details that make a song feel expensive.",
    modalNote: "Coming soon — limited first access.",
  },

  pt: {
    about: "Sobre",
    work: "Trabalhos",
    courses: "Cursos",
    contact: "Contato",
    closeCourses: "Fechar modal de cursos",
    modalEyebrow: "CURSOS POR GABRIEL SOARES",
    modalTitle: "O som por trás das gravações está se tornando um curso.",
    modalParagraphOne:
      "Estou preparando uma experiência premium de aprendizado para músicos, produtores e violonistas que querem entender como gravações profissionais são realmente construídas.",
    modalParagraphTwo:
      "Timbre de violão, decisões de produção, arranjos, fluxo de trabalho, bom gosto e os detalhes que fazem uma música soar cara.",
    modalNote: "Em breve — primeiros acessos limitados.",
  },

  es: {
    about: "Sobre mí",
    work: "Trabajos",
    courses: "Cursos",
    contact: "Contacto",
    closeCourses: "Cerrar modal de cursos",
    modalEyebrow: "CURSOS POR GABRIEL SOARES",
    modalTitle: "El sonido detrás de las grabaciones se está convirtiendo en un curso.",
    modalParagraphOne:
      "Estoy preparando una experiencia premium de aprendizaje para músicos, productores y guitarristas acústicos que quieren entender cómo se construyen realmente las grabaciones profesionales.",
    modalParagraphTwo:
      "Tono de guitarra acústica, decisiones de producción, arreglos, flujo de trabajo, gusto musical y los detalles que hacen que una canción suene cara.",
    modalNote: "Próximamente — primeros accesos limitados.",
  },
};

const t = text[currentLanguage];

const homePath = getLocalizedPath(currentLanguage, "/");

const aboutHref = getLocalizedPath(currentLanguage, "/about");
const workHref = `${homePath}#work`;
const contactHref = `${homePath}#contact`;

const languageUrls = {
  en: getLocalizedPath("en", currentPath),
  pt: getLocalizedPath("pt", currentPath),
  es: getLocalizedPath("es", currentPath),
};

const currentLanguageOption = languageOptions[currentLanguage];
---

<header class="navbar">

  <div class="brand"></div>

  <nav>
    <a href={aboutHref}>{t.about}</a>
    <a href={workHref}>{t.work}</a>
    <button class="nav-link courses-button" type="button">{t.courses}</button>
    <a href={contactHref}>{t.contact}</a>
  </nav>

  <details class="language">
    <summary class="language-button">
      <span>{currentLanguageOption.flag}</span>
      <span>{currentLanguageOption.short}</span>
      <span class="chevron">▾</span>
    </summary>

    <div class="language-menu">
      <a
        href={languageUrls.en}
        data-lang="en"
        class:list={{ active: currentLanguage === "en" }}
      >
        🇺🇸 English
      </a>

      <a
        href={languageUrls.pt}
        data-lang="pt"
        class:list={{ active: currentLanguage === "pt" }}
      >
        🇧🇷 Português
      </a>

      <a
        href={languageUrls.es}
        data-lang="es"
        class:list={{ active: currentLanguage === "es" }}
      >
        🇪🇸 Español
      </a>
    </div>
   </details>

  <button class="mobile-menu-button" type="button" aria-label="Open menu">
    <span></span>
    <span></span>
  </button>

</header>

<div class="mobile-menu-panel" id="mobileMenu">

  <div class="mobile-menu-card">

    <div class="mobile-menu-top">
      <span>Gabriel Soares</span>

      <button class="mobile-menu-close" type="button" aria-label="Close menu">
        ×
      </button>
    </div>

    <div class="mobile-menu-links">
      <a href={aboutHref}>{t.about}</a>
      <a href={workHref}>{t.work}</a>
      <button class="nav-link courses-button" type="button">{t.courses}</button>
      <a href={contactHref}>{t.contact}</a>
    </div>

    <div class="mobile-language-links">
      <a
        href={languageUrls.en}
        data-lang="en"
        class:list={{ active: currentLanguage === "en" }}
      >
        🇺🇸 English
      </a>

      <a
        href={languageUrls.pt}
        data-lang="pt"
        class:list={{ active: currentLanguage === "pt" }}
      >
        🇧🇷 Português
      </a>

      <a
        href={languageUrls.es}
        data-lang="es"
        class:list={{ active: currentLanguage === "es" }}
      >
        🇪🇸 Español
      </a>
    </div>

  </div>

</div>
   

<div class="soon-modal" id="soonModal">
  <div class="soon-card">
    <button class="soon-close" type="button" aria-label={t.closeCourses}>×</button>

    <p class="soon-eyebrow">{t.modalEyebrow}</p>

    <h2>{t.modalTitle}</h2>

    <p>
      {t.modalParagraphOne}
    </p>

    <p>
      {t.modalParagraphTwo}
    </p>

    <span class="soon-note">
      {t.modalNote}
    </span>
  </div>
</div>

<script is:inline>
const language = document.querySelector(".language");
const languageLinks = document.querySelectorAll("[data-lang]");
const coursesButtons = document.querySelectorAll(".courses-button");
const soonModal = document.querySelector("#soonModal");
const soonClose = document.querySelector(".soon-close");

const mobileMenuButton = document.querySelector(".mobile-menu-button");
const mobileMenu = document.querySelector("#mobileMenu");
const mobileMenuClose = document.querySelector(".mobile-menu-close");
const mobileMenuLinks = document.querySelectorAll(".mobile-menu-links a");

languageLinks.forEach((link) => {
  link.addEventListener("click", () => {
    const selectedLanguage = link.getAttribute("data-lang");

    if (!selectedLanguage) return;

    localStorage.setItem("gabriel-site-language", selectedLanguage);
  });
});

document.addEventListener("click", (event) => {
  if (
    language &&
    event.target instanceof Node &&
    !language.contains(event.target)
  ) {
    language.removeAttribute("open");
  }

  if (!soonModal?.classList.contains("active")) return;

  const card = document.querySelector(".soon-card");
  const clickedCoursesButton = Array.from(coursesButtons).some((button) => {
    return event.target instanceof Node && button.contains(event.target);
  });

  if (
    card &&
    event.target instanceof Node &&
    !card.contains(event.target) &&
    !clickedCoursesButton
  ) {
    soonModal.classList.remove("active");
    document.body.classList.remove("modal-open");
  }
});

coursesButtons.forEach((button) => {
  button.addEventListener("click", () => {
    mobileMenu?.classList.remove("active");
    soonModal?.classList.add("active");
    document.body.classList.add("modal-open");
  });
});

mobileMenuButton?.addEventListener("click", () => {
  mobileMenu?.classList.add("active");
});

mobileMenuClose?.addEventListener("click", () => {
  mobileMenu?.classList.remove("active");
});

mobileMenuLinks.forEach((link) => {
  link.addEventListener("click", () => {
    mobileMenu?.classList.remove("active");
  });
});

soonClose?.addEventListener("click", () => {
  soonModal?.classList.remove("active");
  document.body.classList.remove("modal-open");
});

document.addEventListener("keydown", (event) => {
  if (event.key !== "Escape") return;

  soonModal?.classList.remove("active");
  document.body.classList.remove("modal-open");
});
</script>

<style>
.navbar{
  position:absolute;
  top:24px;
  left:50%;
  transform:translateX(-50%);
  width:min(1200px,92%);
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:18px 28px;
  border-radius:20px;
  background:transparent;
  border:none;
  outline:none;
  box-shadow:none;
  z-index:999;
}

.brand{
  width:145px;
  flex-shrink:0;
}

nav{
  display:flex;
  align-items:center;
  gap:34px;
  margin-left:auto;
  margin-right:40px;
}

nav a,
.nav-link{
  text-decoration:none;
  font-size:.92rem;
  color:white;
  opacity:.75;
  transition:.3s;
}

.nav-link{
  background:none;
  border:none;
  padding:0;
  font:inherit;
  cursor:pointer;
}

nav a:hover,
.nav-link:hover{
  opacity:1;
  color:var(--gold);
}

.language{
  position:relative;
  width:145px;
  display:flex;
  justify-content:flex-end;
}

.language summary{
  list-style:none;
}

.language summary::-webkit-details-marker{
  display:none;
}

.language-button{
  border:none;
  background:rgba(255,255,255,.06);
  color:white;
  border-radius:999px;
  padding:9px 13px;
  display:flex;
  align-items:center;
  gap:7px;
  font:inherit;
  font-size:.85rem;
  cursor:pointer;
  opacity:.82;
  transition:.3s;
}

.language-button:hover{
  opacity:1;
  background:rgba(255,255,255,.12);
}

.chevron{
  font-size:.7rem;
  opacity:.65;
}

.language-menu{
  position:absolute;
  top:44px;
  right:0;
  min-width:170px;
  display:flex;
  flex-direction:column;
  padding:8px;
  border-radius:16px;
  background:rgba(10,10,10,.92);
  backdrop-filter:blur(18px);
  -webkit-backdrop-filter:blur(18px);
  box-shadow:0 20px 60px rgba(0,0,0,.35);
}

.language:not([open]) .language-menu{
  display:none;
}

.language-menu a{
  text-decoration:none;
  color:white;
  padding:11px 12px;
  border-radius:10px;
  font-size:.88rem;
  opacity:.82;
  transition:.25s;
}

.language-menu a:hover,
.language-menu a.active{
  opacity:1;
  background:rgba(255,255,255,.08);
  color:var(--gold);
}

.soon-modal{
  position:fixed;
  inset:0;
  display:none;
  align-items:center;
  justify-content:center;
  background:rgba(0,0,0,.55);
  backdrop-filter:blur(18px);
  -webkit-backdrop-filter:blur(18px);
  z-index:1000;
  padding:24px;
}

.soon-modal.active{
  display:flex;
}

:global(body.modal-open){
  overflow:hidden;
}

.soon-card{
  position:relative;
  width:min(620px,92%);
  padding:54px;
  border-radius:32px;
  background:
    linear-gradient(
      145deg,
      rgba(22,22,22,.98),
      rgba(7,7,7,.98)
    );
  border:1px solid rgba(255,255,255,.11);
  box-shadow:
    0 40px 120px rgba(0,0,0,.65),
    inset 0 1px 0 rgba(255,255,255,.08);
  text-align:left;
  animation:modalIn .45s ease forwards;
}

.soon-card::before{
  content:"";
  position:absolute;
  inset:-1px;
  border-radius:32px;
  background:
    linear-gradient(
      135deg,
      rgba(210,176,120,.45),
      transparent 35%,
      transparent 65%,
      rgba(210,176,120,.18)
    );
  z-index:-1;
  opacity:.65;
}

.soon-close{
  position:absolute;
  top:20px;
  right:20px;
  width:36px;
  height:36px;
  border:none;
  border-radius:999px;
  background:rgba(255,255,255,.08);
  color:white;
  font-size:1.35rem;
  cursor:pointer;
  transition:.3s;
}

.soon-close:hover{
  background:white;
  color:black;
}

.soon-eyebrow{
  color:var(--gold);
  letter-spacing:5px;
  font-size:.72rem;
  margin-bottom:22px;
  font-weight:700;
}

.soon-card h2{
  color:white;
  font-size:3.1rem;
  line-height:1.04;
  letter-spacing:-1.5px;
  margin-bottom:26px;
  max-width:520px;
}

.soon-card p{
  color:#cfcfcf;
  font-size:1.04rem;
  line-height:1.85;
  margin-bottom:18px;
  max-width:520px;
}

.soon-note{
  display:inline-block;
  margin-top:20px;
  padding:13px 18px;
  border-radius:999px;
  background:rgba(210,176,120,.09);
  border:1px solid rgba(210,176,120,.24);
  color:#f0d7a3;
  font-size:.9rem;
  font-weight:700;
}

@keyframes modalIn{
  from{
    opacity:0;
    transform:translateY(24px) scale(.96);
  }

  to{
    opacity:1;
    transform:translateY(0) scale(1);
  }
}

@media(max-width:900px){
  nav{
    display:none;
  }

  .brand{
    width:0;
  }

  .language{
    width:auto;
  }

  .navbar{
    width:auto;
    right:22px;
    left:auto;
    transform:none;
    padding:18px 22px;
  }
}

@media(max-width:700px){
  .soon-card{
    width:min(460px,90%);
    padding:42px 28px;
    border-radius:26px;
  }

  .soon-card h2{
    font-size:2.35rem;
  }
}

.mobile-menu-button,
.mobile-menu-panel{
  display:none;
}

@media(max-width:900px){
  .navbar{
    gap:10px;
  }

  .mobile-menu-button{
    width:42px;
    height:42px;
    border:none;
    border-radius:999px;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    gap:5px;
    background:rgba(255,255,255,.08);
    color:white;
    cursor:pointer;
    backdrop-filter:blur(14px);
    -webkit-backdrop-filter:blur(14px);
  }

  .mobile-menu-button span{
    width:17px;
    height:2px;
    border-radius:999px;
    background:white;
    opacity:.9;
  }

  .mobile-menu-panel{
    position:fixed;
    inset:0;
    z-index:998;
    display:none;
    align-items:flex-start;
    justify-content:center;
    padding:92px 18px 18px;
    background:rgba(0,0,0,.52);
    backdrop-filter:blur(18px);
    -webkit-backdrop-filter:blur(18px);
  }

  .mobile-menu-panel.active{
    display:flex;
  }

  .mobile-menu-card{
    width:min(420px,100%);
    border-radius:28px;
    padding:20px;
    background:
      linear-gradient(
        145deg,
        rgba(20,20,20,.96),
        rgba(6,6,6,.96)
      );
    border:1px solid rgba(255,255,255,.11);
    box-shadow:
      0 30px 100px rgba(0,0,0,.58),
      inset 0 1px 0 rgba(255,255,255,.08);
  }

  .mobile-menu-top{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:18px;
    padding-bottom:16px;
    border-bottom:1px solid rgba(255,255,255,.08);
  }

  .mobile-menu-top span{
    color:white;
    font-size:1rem;
    font-weight:700;
    letter-spacing:.3px;
  }

  .mobile-menu-close{
    width:36px;
    height:36px;
    border:none;
    border-radius:999px;
    background:rgba(255,255,255,.08);
    color:white;
    font-size:1.35rem;
    cursor:pointer;
  }

  .mobile-menu-links{
    display:flex;
    flex-direction:column;
    gap:8px;
  }

  .mobile-menu-links a,
  .mobile-menu-links .nav-link{
    width:100%;
    min-height:48px;
    display:flex;
    align-items:center;
    padding:0 16px;
    border-radius:16px;
    color:white;
    text-decoration:none;
    background:rgba(255,255,255,.045);
    border:1px solid rgba(255,255,255,.06);
    font-size:.96rem;
    opacity:.92;
  }

  .mobile-menu-links .nav-link{
    font:inherit;
    cursor:pointer;
  }

  .mobile-language-links{
    display:grid;
    grid-template-columns:1fr;
    gap:8px;
    margin-top:18px;
    padding-top:18px;
    border-top:1px solid rgba(255,255,255,.08);
  }

  .mobile-language-links a{
    min-height:44px;
    display:flex;
    align-items:center;
    padding:0 14px;
    border-radius:14px;
    color:rgba(255,255,255,.82);
    text-decoration:none;
    background:rgba(255,255,255,.035);
    font-size:.88rem;
  }

  .mobile-language-links a.active{
    color:#f0d7a3;
    background:rgba(210,176,120,.1);
  }
}
</style>