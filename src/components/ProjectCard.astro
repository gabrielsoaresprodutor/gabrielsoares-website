---
interface Project {
  slug: string;
  artist: string;
  title: string;
  highlight?: string;
  image: {
    src: string;
  };
}

interface Props {
  project: Project;
  priority?: boolean;
}

type SiteLanguage = "en" | "pt" | "es";

const { project, priority = false } = Astro.props;

const currentPath = Astro.url.pathname;

const getRouteLanguage = (pathname: string): SiteLanguage => {
  if (pathname === "/pt" || pathname.startsWith("/pt/")) return "pt";
  if (pathname === "/es" || pathname.startsWith("/es/")) return "es";
  return "en";
};

const currentLanguage = getRouteLanguage(currentPath);

const projectHref =
  currentLanguage === "en"
    ? `/work/${project.slug}`
    : `/${currentLanguage}/work/${project.slug}`;
---

<a class="card" href={projectHref}>

  <img
    src={project.image.src}
    alt={`${project.artist} - ${project.title}`}
    width="640"
    height="640"
    loading={priority ? "eager" : "lazy"}
    fetchpriority={priority ? "high" : "auto"}
    decoding="async"
  />

  <div class="info">
    <p>{project.artist}</p>
    <h3>{project.title}</h3>

    {project.highlight && (
      <span class="badge">{project.highlight}</span>
    )}
  </div>

</a>

<style>
.card{
  text-decoration:none;
  color:white;
  background:#141414;
  border:1px solid rgba(255,255,255,.08);
  border-radius:22px;
  overflow:hidden;
  transition:.35s;
}

.card:hover{
  transform:translateY(-8px);
  border-color:rgba(210,176,120,.35);
}

.card img{
  width:100%;
  height:auto;
  aspect-ratio:1/1;
  object-fit:cover;
  display:block;
  background:#0b0b0b;
}

.info{
  padding:26px;
}

.info p{
  color:#aaa;
  letter-spacing:2px;
  text-transform:uppercase;
  font-size:.75rem;
  margin-bottom:10px;
}

h3{
  font-size:2rem;
  margin-bottom:14px;
}

.badge{
  display:inline-flex;
  align-items:center;
  width:max-content;
  max-width:100%;
  margin-top:8px;
  padding:8px 15px;
  border:1px solid rgba(255,255,255,.18);
  border-radius:999px;
  background:rgba(255,255,255,.03);
  color:#fff;
  font-size:.82rem;
  font-weight:500;
  line-height:1.2;
  box-shadow:inset 0 0 0 1px rgba(255,255,255,.03);
}
</style>