---
type SiteLanguage = "en" | "pt" | "es";

const currentPath = Astro.url.pathname;

const getRouteLanguage = (pathname: string): SiteLanguage => {
  if (pathname === "/pt" || pathname.startsWith("/pt/")) return "pt";
  if (pathname === "/es" || pathname.startsWith("/es/")) return "es";
  return "en";
};

const removeLanguagePrefix = (pathname: string) => {
  if (pathname === "/pt" || pathname === "/es") return "/";
  if (pathname.startsWith("/pt/")) return pathname.replace("/pt", "") || "/";
  if (pathname.startsWith("/es/")) return pathname.replace("/es", "") || "/";
  return pathname || "/";
};

const getLocalizedPath = (language: SiteLanguage, pathname: string) => {
  const cleanPath = removeLanguagePrefix(pathname);

  if (language === "en") return cleanPath;
  if (cleanPath === "/") return `/${language}`;
  return `/${language}${cleanPath}`;
};

const currentLanguage = getRouteLanguage(currentPath);

const footerText: Record<
  SiteLanguage,
  {
    homeAria: string;
    tagline: string;
    navAria: string;
    about: string;
    credits: string;
    work: string;
    contact: string;
    socialsAria: string;
    instagramAria: string;
    youtubeAria: string;
    spotifyAria: string;
    copyright: string;
    terms: string;
    privacy: string;
  }
> = {
  en: {
    homeAria: "Back to home",
    tagline: "Music Producer • Acoustic Guitarist • Multi-Instrumentalist",
    navAria: "Footer navigation",
    about: "About",
    credits: "Credits",
    work: "Work",
    contact: "Contact",
    socialsAria: "Official social links",
    instagramAria: "Gabriel Soares on Instagram",
    youtubeAria: "Gabriel Soares on YouTube",
    spotifyAria: "Gabriel Soares on Spotify",
    copyright: "© 2026 Gabriel Soares. Official website.",
    terms: "Terms",
    privacy: "Privacy",
  },

  pt: {
    homeAria: "Voltar para o início",
    tagline: "Produtor Musical • Violonista de Estúdio • Multi-Instrumentista",
    navAria: "Navegação do rodapé",
    about: "Sobre",
    credits: "Créditos",
    work: "Trabalhos",
    contact: "Contato",
    socialsAria: "Links sociais oficiais",
    instagramAria: "Gabriel Soares no Instagram",
    youtubeAria: "Gabriel Soares no YouTube",
    spotifyAria: "Gabriel Soares no Spotify",
    copyright: "© 2026 Gabriel Soares. Site oficial.",
    terms: "Termos",
    privacy: "Privacidade",
  },

  es: {
    homeAria: "Volver al inicio",
    tagline: "Productor Musical • Guitarrista Acústico de Estudio • Multiinstrumentista",
    navAria: "Navegación del pie de página",
    about: "Sobre mí",
    credits: "Créditos",
    work: "Proyectos",
    contact: "Contacto",
    socialsAria: "Links sociales oficiales",
    instagramAria: "Gabriel Soares en Instagram",
    youtubeAria: "Gabriel Soares en YouTube",
    spotifyAria: "Gabriel Soares en Spotify",
    copyright: "© 2026 Gabriel Soares. Sitio oficial.",
    terms: "Términos",
    privacy: "Privacidad",
  },
};

const t = footerText[currentLanguage];

const homeHref = getLocalizedPath(currentLanguage, "/");
const aboutHref = getLocalizedPath(currentLanguage, "/about");
const creditsHref = getLocalizedPath(currentLanguage, "/credits");
const workHref = `${homeHref}#work`;
const contactHref = `${homeHref}#contact`;
const termsHref = getLocalizedPath(currentLanguage, "/terms");
const privacyHref = getLocalizedPath(currentLanguage, "/privacy");
---

<footer class="footer">

  <div class="footer-top">

    <div class="brand">
      <h2>
        <a
          class="brand-home"
          href={homeHref}
          aria-label={t.homeAria}
          data-home-path={homeHref}
        >
          Gabriel Soares
        </a>
      </h2>

      <p>{t.tagline}</p>
    </div>

    <nav class="footer-nav" aria-label={t.navAria}>
      <a href={aboutHref}>{t.about}</a>
      <a href={creditsHref}>{t.credits}</a>
      <a href={workHref}>{t.work}</a>
      <a href={contactHref}>{t.contact}</a>
    </nav>

    <div class="socials" aria-label={t.socialsAria}>

      <a
        class="instagram"
        href="https://www.instagram.com/gabrielsoaresprodutor/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={t.instagramAria}
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4c0 3.2-2.6 5.8-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8C2 4.6 4.6 2 7.8 2Zm0 2C5.7 4 4 5.7 4 7.8v8.4C4 18.3 5.7 20 7.8 20h8.4c2.1 0 3.8-1.7 3.8-3.8V7.8C20 5.7 18.3 4 16.2 4H7.8Zm4.2 3.1A4.9 4.9 0 1 1 12 16.9 4.9 4.9 0 0 1 12 7.1Zm0 2A2.9 2.9 0 1 0 12 14.9 2.9 2.9 0 0 0 12 9.1Zm5.1-2.45a1.15 1.15 0 1 1-1.15 1.15 1.15 1.15 0 0 1 1.15-1.15Z" />
        </svg>
      </a>

      <a
        class="youtube"
        href="https://www.youtube.com/@gabrielsoaresprodutor"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={t.youtubeAria}
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M21.6 7.2s-.2-1.5-.8-2.1c-.8-.8-1.7-.8-2.1-.9C15.8 4 12 4 12 4s-3.8 0-6.7.2c-.4.1-1.3.1-2.1.9-.6.6-.8 2.1-.8 2.1S2.2 9 2.2 10.9v1.8c0 1.9.2 3.7.2 3.7s.2 1.5.8 2.1c.8.8 1.9.8 2.4.9 1.8.2 6.4.2 6.4.2s3.8 0 6.7-.2c.4-.1 1.3-.1 2.1-.9.6-.6.8-2.1.8-2.1s.2-1.8.2-3.7v-1.8c0-1.9-.2-3.7-.2-3.7ZM10.1 14.9V8.6l5.9 3.2-5.9 3.1Z" />
        </svg>
      </a>

      <a
        class="spotify"
        href="https://open.spotify.com/intl-pt/artist/4llhbsPozmyRXlJWNmAVHb"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={t.spotifyAria}
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm4.6 14.4c-.2.3-.5.4-.8.2-2.2-1.3-5-1.6-8.3-.9-.3.1-.6-.1-.7-.5-.1-.3.1-.6.5-.7 3.6-.8 6.8-.4 9.3 1.1.3.2.4.5.2.8Zm1.2-2.6c-.2.4-.7.5-1 .3-2.5-1.5-6.4-2-9.4-1.1-.4.1-.8-.1-.9-.5s.1-.8.5-.9c3.4-1 7.7-.5 10.6 1.2.3.2.5.7.2 1Zm.1-2.8C15 9.3 10.2 9.1 7.4 9.8c-.5.1-1-.2-1.1-.7-.1-.5.2-1 .7-1.1 3.3-.7 8.6-.5 12 1.5.4.3.6.8.3 1.3-.3.4-.9.6-1.4.2Z" />
        </svg>
      </a>

    </div>

  </div>

  <div class="footer-bottom">

    <p>
      {t.copyright}
    </p>

    <div class="legal-links">
      <a href={termsHref}>{t.terms}</a>
      <a href={privacyHref}>{t.privacy}</a>
    </div>

  </div>

</footer>

<style>
.footer{
  background:#080808;
  color:white;
  padding:58px 6% 34px;
  border-top:1px solid rgba(255,255,255,.08);
}

.footer-top{
  max-width:1200px;
  margin:auto;
  display:grid;
  grid-template-columns:1fr auto auto;
  align-items:center;
  gap:42px;
}

.brand h2{
  font-size:1.65rem;
  margin-bottom:8px;
}

.brand-home{
  display:inline-block;
  color:white !important;
  text-decoration:none !important;
  cursor:pointer;
  transition:
    color .18s ease,
    transform .18s ease,
    text-shadow .18s ease;
}

.brand-home:visited,
.brand-home:active,
.brand-home:focus{
  color:white !important;
  text-decoration:none !important;
}

.brand-home:hover{
  color:#f0d7a3 !important;
  text-decoration:none !important;
  transform:translateY(-2px);
  text-shadow:0 0 24px rgba(240,215,163,.42);
}

.brand p{
  color:rgba(255,255,255,.56);
  font-size:.9rem;
  line-height:1.6;
}

.footer-nav{
  display:flex;
  align-items:center;
  gap:24px;
}

.footer-nav a,
.legal-links a{
  color:white;
  text-decoration:none;
  font-size:.88rem;
  font-weight:700;
  opacity:.74;
  transition:.25s ease;
}

.footer-nav a:hover,
.legal-links a:hover{
  color:var(--gold);
  opacity:1;
}

.socials{
  display:flex;
  gap:12px;
}

.socials a{
  width:50px;
  height:50px;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  text-decoration:none;
  transition:.3s;
  background:rgba(255,255,255,.055);
  border:1px solid rgba(255,255,255,.12);
  box-shadow:
    0 10px 30px rgba(0,0,0,.22),
    inset 0 1px 0 rgba(255,255,255,.08);
}

.socials a:hover{
  transform:translateY(-3px);
}

.socials svg{
  width:34px;
  height:34px;
  fill:currentColor;
}

.socials .instagram{
  color:#E4405F;
}

.socials .instagram:hover{
  background:
    radial-gradient(circle at 30% 110%, rgba(252,175,69,.34), transparent 34%),
    radial-gradient(circle at 70% 0%, rgba(131,58,180,.32), transparent 38%),
    rgba(228,64,95,.16);
  border-color:rgba(228,64,95,.55);
}

.socials .youtube{
  color:#FF0000;
}

.socials .youtube:hover{
  background:rgba(255,0,0,.16);
  border-color:rgba(255,0,0,.55);
}

.socials .spotify{
  color:#1DB954;
}

.socials .spotify:hover{
  background:rgba(29,185,84,.16);
  border-color:rgba(29,185,84,.55);
}

.footer-bottom{
  max-width:1200px;
  margin:38px auto 0;
  padding-top:26px;
  border-top:1px solid rgba(255,255,255,.07);
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:24px;
}

.footer-bottom p{
  color:rgba(255,255,255,.44);
  font-size:.82rem;
  line-height:1.6;
}

.legal-links{
  display:flex;
  align-items:center;
  gap:20px;
}

@media(max-width:950px){
  .footer-top{
    grid-template-columns:1fr;
    gap:30px;
  }

  .footer-nav{
    flex-wrap:wrap;
  }

  .footer-bottom{
    flex-direction:column;
    align-items:flex-start;
  }
}

@media(max-width:700px){
  .footer{
    padding:52px 6% 32px;
  }

  .footer-nav{
    gap:18px;
  }

  .socials{
    flex-wrap:wrap;
  }

  .socials a{
    width:48px;
    height:48px;
  }

  .socials svg{
    width:32px;
    height:32px;
  }
}
</style>

<script is:inline>
const brandHome = document.querySelector(".brand-home");

brandHome?.addEventListener("click", (event) => {
  const homePath = brandHome.getAttribute("data-home-path") || "/";
  const currentPath = window.location.pathname.replace(/\/$/, "") || "/";
  const normalizedHomePath = homePath.replace(/\/$/, "") || "/";

  const isHomePage =
    currentPath === normalizedHomePath ||
    currentPath === "/index.html" ||
    currentPath === "/pt/index.html" ||
    currentPath === "/es/index.html";

  if (!isHomePage) return;

  event.preventDefault();

  const start = window.scrollY;
  const duration = 260;
  const startTime = performance.now() - 45;

  const easeOutExpo = (progress) => {
    return progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
  };

  const scrollToTop = (currentTime) => {
    const elapsed = currentTime - startTime;
    const progress = Math.min(elapsed / duration, 1);
    const easedProgress = easeOutExpo(progress);

    window.scrollTo(0, start * (1 - easedProgress));

    if (progress < 1) {
      requestAnimationFrame(scrollToTop);
    }
  };

  requestAnimationFrame(scrollToTop);
});
</script>
