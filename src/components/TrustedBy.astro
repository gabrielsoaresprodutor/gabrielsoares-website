<section class="trusted" id="trusted">

  <div class="container">

    <div class="heading">
      <p class="eyebrow">{t.eyebrow}</p>

      <h2>{t.title}</h2>
    </div>

    <div class="carousel" aria-label={t.ariaLabel}>

      {testimonials.map((item) => (

        <article class="testimonial">

          <div class={`photo-side ${item.avatarClass}-wrap`}>
            {item.image ? (
              <img
                src={item.image.src}
                alt={item.name}
                data-photo-name={item.name}
                data-avatar-class={item.avatarClass}
                class={`avatar ${item.avatarClass}`}
              />
            ) : (
              <div class="initials-avatar">
                {item.initials}
              </div>
            )}
          </div>

          <div class="testimonial-content">

            <div class="person">
              <h3>{item.name}</h3>

              <p class="title">{item.title[currentLanguage]}</p>
              {item.location && (
                <p class="location">{item.location}</p>
)}

              {item.achievements[currentLanguage] && (
                <p class="achievements" set:html={item.achievements[currentLanguage]} />
              )}

              {item.workedWith[currentLanguage] && (
                <p class="worked" set:html={item.workedWith[currentLanguage]} />
              )}
            </div>

            <blockquote>
              “{item.quote[currentLanguage]}”
            </blockquote>

          </div>

        </article>

      ))}

    </div>

  </div>

</section>

<style>
.trusted{
  background:#050505;
  color:white;
  padding:120px 0;
  overflow:hidden;
}

.container{
