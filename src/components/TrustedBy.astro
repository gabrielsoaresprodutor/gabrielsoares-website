        ">Resetar ajustes</button>

        <span id="photoToolStatus" style="
          color:#9f9f9f;
          font-size:.72rem;
          align-self:center;
        ">Tool closed</span>
      </div>
    </div>
  `;

  document.body.appendChild(tool);

  const toggleButton = document.querySelector("#photoToolToggle");
  const panel = document.querySelector("#photoToolPanel");
  const output = document.querySelector("#photoToolOutput");
  const copyButton = document.querySelector("#photoToolCopy");
  const resetButton = document.querySelector("#photoToolReset");
  const status = document.querySelector("#photoToolStatus");

  const photoState = new Map();

  let photoToolEnabled = false;

  const setPhotosCursor = () => {
    editablePhotos.forEach((photo) => {
      photo.style.cursor = photoToolEnabled ? "grab" : "";
      photo.style.userSelect = photoToolEnabled ? "none" : "";
      photo.style.touchAction = photoToolEnabled ? "none" : "";
    });
  };

  toggleButton?.addEventListener("click", () => {
    if (!panel) return;

    photoToolEnabled = !photoToolEnabled;

    panel.style.display = photoToolEnabled ? "block" : "none";
    toggleButton.textContent = photoToolEnabled ? "▼" : "▲";

    setPhotosCursor();

    if (status) {
      status.textContent = photoToolEnabled ? "Tool open" : "Tool closed";
    }
  });

  const getStorageKey = (photo) => {
    return `testimonial-photo-${photo.dataset.avatarClass}`;
  };

  const parseInitialTransform = (photo) => {
    const computedStyle = window.getComputedStyle(photo);
    const matrix = new DOMMatrixReadOnly(computedStyle.transform);

    return {
      x: Math.round(matrix.m41 || 0),
      y: Math.round(matrix.m42 || 0),
      scale: Number((matrix.a || 1).toFixed(2)),
    };
  };

  const applyTransform = (photo, state) => {
    photo.style.transform =
      `translateX(${state.x}px) translateY(${state.y}px) scale(${state.scale})`;
  };

  const saveTransform = (photo, state) => {
    localStorage.setItem(getStorageKey(photo), JSON.stringify(state));
  };

  const updateOutput = () => {
    const desktopBlocks = [];
    const mobileBlocks = [];

    editablePhotos.forEach((photo) => {
      const state = photoState.get(photo);
      const className = photo.dataset.avatarClass;

      if (!state || !className) return;

      desktopBlocks.push(`.photo-side .${className}{
  width:${state.desktopWidth}px;
  height:${state.desktopHeight}px;
  max-width:none;
  object-position:center;
  transform:translateX(${state.x}px) translateY(${state.y}px) scale(${state.scale});
}`);

      mobileBlocks.push(`  .photo-side .${className}{
    width:${state.mobileWidth}px;
    height:${state.mobileHeight}px;
    max-width:none;
    object-position:center;
    transform:translateX(${state.x}px) translateY(${state.y}px) scale(${state.scale});
  }`);
    });

    if (!output) return;

    output.value = `${desktopBlocks.join("\n\n")}

@media(max-width:700px){
${mobileBlocks.join("\n\n")}
}`;
  };

  editablePhotos.forEach((photo) => {
    const initial = parseInitialTransform(photo);
    const saved = localStorage.getItem(getStorageKey(photo));
    const parsedSaved = saved ? JSON.parse(saved) : null;

    const state = {
      x: parsedSaved?.x ?? initial.x,
      y: parsedSaved?.y ?? initial.y,
      scale: parsedSaved?.scale ?? initial.scale,
      desktopWidth: Number.parseInt(window.getComputedStyle(photo).width) || 118,
      desktopHeight: Number.parseInt(window.getComputedStyle(photo).height) || 118,
      mobileWidth: photo.classList.contains("flavio-avatar") ? 155 :
        photo.classList.contains("samuel-avatar") ? 170 :
        photo.classList.contains("myson-avatar") ? 144 :
        photo.classList.contains("ricardo-avatar") ? 136 :
        photo.classList.contains("pablo-avatar") ? 144 :
        photo.classList.contains("sergio-avatar") ? 104 :
        photo.classList.contains("kleber-avatar") ? 104 :
        photo.classList.contains("gui-avatar") ? 104 :
        photo.classList.contains("carlos-avatar") ? 104 :
        photo.classList.contains("renan-avatar") ? 104 :
        photo.classList.contains("luciano-avatar") ? 104 :
        104,
      mobileHeight: photo.classList.contains("flavio-avatar") ? 155 :
        photo.classList.contains("samuel-avatar") ? 170 :
        photo.classList.contains("myson-avatar") ? 144 :
        photo.classList.contains("ricardo-avatar") ? 136 :
        photo.classList.contains("pablo-avatar") ? 144 :
        photo.classList.contains("sergio-avatar") ? 104 :
        photo.classList.contains("kleber-avatar") ? 104 :
        photo.classList.contains("gui-avatar") ? 104 :
        photo.classList.contains("carlos-avatar") ? 104 :
        photo.classList.contains("renan-avatar") ? 104 :
        photo.classList.contains("luciano-avatar") ? 104 :
        104,
    };

    photoState.set(photo, state);
    applyTransform(photo, state);

    let isDragging = false;
    let startX = 0;
    let startY = 0;

    photo.addEventListener("mousedown", (event) => {
      if (!photoToolEnabled) return;

      isDragging = true;
      startX = event.clientX - state.x;
      startY = event.clientY - state.y;

      photo.style.cursor = "grabbing";
      event.preventDefault();
    });

    window.addEventListener("mousemove", (event) => {
      if (!photoToolEnabled || !isDragging) return;

      state.x = Math.round(event.clientX - startX);
      state.y = Math.round(event.clientY - startY);

      applyTransform(photo, state);
      saveTransform(photo, state);
      updateOutput();
    });

    window.addEventListener("mouseup", () => {
      if (!isDragging) return;

      isDragging = false;

      if (photoToolEnabled) {
        photo.style.cursor = "grab";
      }

      saveTransform(photo, state);
      updateOutput();

      if (status) {
        status.textContent = `${photo.dataset.photoName} salvo localmente`;
      }
    });

    photo.addEventListener("wheel", (event) => {
      if (!photoToolEnabled) return;

      event.preventDefault();

      if (event.deltaY < 0) {
        state.scale += 0.04;
      } else {
        state.scale -= 0.04;
      }

      state.scale = Number(Math.max(.7, Math.min(state.scale, 3)).toFixed(2));

      applyTransform(photo, state);
      saveTransform(photo, state);
      updateOutput();

      if (status) {
        status.textContent = `${photo.dataset.photoName} zoom ${state.scale}`;
      }
    });
  });

  copyButton?.addEventListener("click", async () => {
    if (!output) return;

    await navigator.clipboard.writeText(output.value);

    if (status) {
      status.textContent = "CSS copiado";
    }
  });

  resetButton?.addEventListener("click", () => {
    editablePhotos.forEach((photo) => {
      localStorage.removeItem(getStorageKey(photo));
      photo.style.transform = "";
    });

    if (status) {
      status.textContent = "Ajustes apagados. Recarregue a página.";
    }
  });

  setPhotosCursor();
  updateOutput();
}
</script>