  display:grid;
  grid-auto-flow:column;
  grid-auto-columns:minmax(460px, 560px);
  gap:28px;
  overflow-x:auto;
  overscroll-behavior-inline:contain;
  scroll-snap-type:x mandatory;
  scroll-padding-inline:6%;
  padding:8px 6% 34px;
