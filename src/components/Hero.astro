---
import heroImage from "../assets/images/hero.jpg";

type SiteLanguage = "en" | "pt" | "es";

const currentPath = Astro.url.pathname;

const getRouteLanguage = (pathname: string): SiteLanguage => {
  if (pathname === "/pt" || pathname.startsWith("/pt/")) return "pt";
  if (pathname === "/es" || pathname.startsWith("/es/")) return "es";
  return "en";
};

const currentLanguage = getRouteLanguage(currentPath);

const heroText: Record<
  SiteLanguage,
  {
    eyebrow: string;
    title: string;
    description: string;
    primaryButton: string;
    secondaryButton: string;
  }
> = {
  en: {
    eyebrow: "MUSIC PRODUCER\nACOUSTIC GUITARIST",
    title: "Gabriel Soares",
    description:
      "Brazilian music producer, studio acoustic guitarist and multi-instrumentalist crafting refined acoustic guitar recordings, arrangements and production layers for artists, producers and emotionally driven music projects.",
    primaryButton: "Hear My Work",
    secondaryButton: "Start a Project",
  },

  pt: {
    eyebrow: "PRODUTOR MUSICAL\nVIOLONISTA DE ESTÚDIO",
    title: "Gabriel Soares",
    description:
      "Produtor musical brasileiro, violonista de estúdio e multi-instrumentista, criando gravações refinadas de violão, arranjos e camadas de produção para artistas, produtores e projetos musicais com profundidade emocional.",
    primaryButton: "Ouça Meu Trabalho",
    secondaryButton: "Iniciar um Projeto",
  },

  es: {
    eyebrow: "PRODUCTOR MUSICAL\nGUITARRISTA ACÚSTICO DE ESTUDIO",
    title: "Gabriel Soares",
    description:
      "Productor musical brasileño, guitarrista acústico de estudio y multiinstrumentista, creando grabaciones refinadas de guitarra acústica, arreglos y texturas de producción para artistas, productores y proyectos musicales con profundidad emocional.",
    primaryButton: "Escuchar Mi Trabajo",
    secondaryButton: "Iniciar un Proyecto",
  },
};

const t = heroText[currentLanguage];
---

<section
  class="hero"
  style={`background-image:url(${heroImage.src})`}
>

  <div class="overlay"></div>

  <div class="content">

    <p class="eyebrow">
      {t.eyebrow.split("\n").map((line) => (
        <>
          {line}
          <br />
        </>
      ))}
    </p>

    <h1>
      {t.title}
    </h1>

    <p class="description">
      {t.description}
    </p>

    <div class="buttons">

      <a href="#work" class="primary">
        {t.primaryButton}
      </a>

      <a href="#contact" class="secondary">
        {t.secondaryButton}
      </a>

    </div>

  </div>

</section>

<style>
.hero{
  height:100vh;
  display:flex;
  align-items:center;
  background-size:cover;
  background-position:center 35%;
  background-repeat:no-repeat;
  position:relative;
  overflow:hidden;
  color:white;
}

.overlay{
  position:absolute;
  inset:0;
  background:
    linear-gradient(
      90deg,
      rgba(0,0,0,.78) 0%,
      rgba(0,0,0,.58) 45%,
      rgba(0,0,0,.86) 100%
    );
}

.content{
  width:min(1200px,90%);
  margin:0 auto;
  position:relative;
  z-index:2;
  transform:translateY(90px);
}

.eyebrow{
  font-size:.68rem;
  letter-spacing:5px;
  color:var(--gold);
  margin-bottom:22px;
  font-weight:600;
  max-width:420px;
  line-height:1.6;
}

h1{
  font-size:5.4rem;
  line-height:.95;
  margin:0;
  max-width:700px;
}

.description{
  margin-top:34px;
  max-width:680px;
  font-size:1.18rem;
  line-height:2;
  color:#d4d4d4;
}

.buttons{
  display:flex;
  gap:20px;
  margin-top:60px;
}

.buttons a{
  padding:18px 42px;
  text-decoration:none;
  border-radius:14px;
  transition:.35s;
  font-weight:600;
}

.primary{
  background:white;
  color:black;
}

.primary:hover{
  transform:translateY(-4px);
}

.secondary{
  border:1px solid rgba(255,255,255,.25);
  background:rgba(255,255,255,.04);
  backdrop-filter:blur(12px);
  -webkit-backdrop-filter:blur(12px);
  color:white;
}

.secondary:hover{
  background:white;
  color:black;
}

@media(max-width:900px){
  .hero{
    background-position:center;
  }

  .content{
    margin-top:20px;
  }

  h1{
    font-size:3.6rem;
  }

  .description{
    font-size:1rem;
    line-height:1.8;
  }

  .buttons{
    flex-direction:column;
  }
}

</style>