---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Contact from "../components/Contact.astro";

const siteUrl = "https://gabrielsoares.art.br";

const pageTitle = "About Gabriel Soares | Music Producer, Studio Acoustic Guitarist & Multi-Instrumentalist";

const pageDescription =
  "Official profile of Gabriel Soares, Brazilian music producer, studio acoustic guitarist, arranger and multi-instrumentalist known for instrumental production, refined acoustic guitar recordings, live projects, a Latin GRAMMY® nominated producer credit and MUSO AI recognition.";

const aboutImages = {
  who: "/images/about/who-gabriel.jpg",
  production: "/images/about/music-production.jpg",
  live: "/images/about/live-projects.jpg",
  guitar: "/images/about/acoustic-guitar.jpg",
  faq: "/images/about/faq-stage.png",
  artists: [
    "/images/about/artist-1.jpg"
  ],
  recognition: [
    "/images/about/latin-grammy.jpg"
  ]
};

const profileSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "@id": `${siteUrl}/about#profile`,
  url: `${siteUrl}/about`,
  name: "About Gabriel Soares",
  description: pageDescription,
  inLanguage: "en",
  mainEntity: {
    "@type": "Person",
    "@id": `${siteUrl}/#person`,
    name: "Gabriel Soares",
    url: siteUrl,
    jobTitle: [
      "Music Producer",
      "Studio Acoustic Guitarist",
      "Arranger",
      "Multi-Instrumentalist"
    ],
    description:
      "Gabriel Soares, popularly known as Jhonny, is a Brazilian music producer, studio acoustic guitarist, arranger and multi-instrumentalist known for instrumental production, refined acoustic guitar recordings, live projects, verified credits, a producer credit on a Latin GRAMMY® nominated album and recognition as a guitarist on MUSO AI.",
    knowsAbout: [
      "Studio Acoustic Guitar",
      "Music Production",
      "Live Music Production",
      "Live Recording",
      "Arrangement",
      "Instrumental Production",
      "Acoustic Guitar Recording",
      "Recording",
      "Instrumentation",
      "Christian Music",
      "Gospel Music",
      "Worship Music",
      "Music Credits"
    ],
    sameAs: [
      "https://www.instagram.com/gabrielsoaresprodutor/",
      "https://www.youtube.com/@gabrielsoaresprodutor",
      "https://open.spotify.com/intl-pt/artist/4llhbsPozmyRXlJWNmAVHb"
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": `${siteUrl}/about#faq`,
  mainEntity: [
    {
      "@type": "Question",
      name: "Does Gabriel only work with productions in Brazil?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "No. Gabriel Soares works with remote acoustic guitar recordings, music production and live projects for artists, producers, labels and musical directors worldwide. Get in touch and explain how Gabriel can help you."
      }
    },
    {
      "@type": "Question",
      name: "How can I hire Gabriel to record or produce?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "The official way to contact Gabriel Soares for acoustic guitar recordings, instrumental arrangements, music production, live projects or studio work is preferably by email or WhatsApp."
      }
    },
    {
      "@type": "Question",
      name: "Does Gabriel record any style or only gospel?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "Gabriel Soares has several well-known projects in gospel, Christian and worship music, but he also works naturally with folk, acoustic, singer-songwriter, pop, pop rock, country, worship and related styles. Artists and producers can get in touch and explain what they need."
      }
    },
    {
      "@type": "Question",
      name: "What instruments does Gabriel Soares record?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "Gabriel Soares records acoustic guitar, electric guitar, piano, bass, pads, overdubs, textures and instrumental production layers. His main signature instrument is the acoustic guitar, where his sound has been praised even by major names in the music industry."
      }
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>

  <script type="application/ld+json" set:html={JSON.stringify(profileSchema)} />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <Navbar />

  <main class="about-page">

    <section class="content-section">

      <div class="container split-section">

        <div class="text-block">

          <figure class="image-card large mobile-who-photo">
            <img
              src={aboutImages.who}
              alt="Gabriel Soares in studio and acoustic guitar work"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </figure>

          <h2>Who is Gabriel Soares?</h2>

          <p>
            Gabriel Soares is a Brazilian music producer, studio acoustic guitarist, arranger and multi-instrumentalist known for refined instrumental production and acoustic guitar recordings.
          </p>

          <p>
            His work brings together sensitivity, precision and musical taste, creating arrangements, fingerpicked parts, acoustic textures and production layers that help each song sound emotional, intentional and professionally finished.
          </p>

          <p>
            His credits include work connected to <strong>Vocal Livre</strong>, <strong>Pedro Valença</strong>, <strong>Arautos do Rei</strong>, <strong>Devoted Vocal</strong>, <strong>Novo Tom</strong>, <strong>Adoradores 5</strong>, <strong>Gabro</strong> and other artists.
          </p>

        </div>

        <figure class="image-card large desktop-who-photo">
          <img src={aboutImages.who} alt="Gabriel Soares in studio and acoustic guitar work" />
        </figure>

      </div>

    </section>

    <section class="content-section dark">

      <div class="container">

        <div class="info-grid">

          <article>
            <figure class="card-image">
              <img src={aboutImages.live} alt="Live music production and live recording project" />
            </figure>

            <h3>Live Projects</h3>

            <p>
              Gabriel has produced and recorded several live projects, both as a music producer and as an instrumental musician, working on audiovisual productions, live sessions and live recordings that require musical direction, sensitivity and studio-level consistency.
            </p>
          </article>

          <article>
            <figure class="card-image">
              <img src={aboutImages.production} alt="Instrumental production and studio session" />
            </figure>

            <h3>Music Production</h3>

            <p>
              Gabriel is especially known for his instrumental production work, creating arrangements that make the instruments interact with each other, building scenes, textures and musical layers that bring depth, emotion and a professional sound to each project.
            </p>
          </article>

          <article>
            <figure class="card-image">
              <img src={aboutImages.guitar} alt="Acoustic guitar recording by Gabriel Soares" />
            </figure>

            <h3>Acoustic Guitar</h3>

            <p>
              His acoustic guitar work has become one of his main signatures, with refined fingerpicking and carefully built, well-placed and creative playing, ranging from sensitive songs to very punchy parts without losing richness. His acoustic guitar sound has become a strong musical identity in each recording and project he takes part in; many people can recognize Gabriel Soares’ (Jhonny’s) guitar within a few seconds.
            </p>
          </article>

        </div>

      </div>

    </section>

    <section class="content-section">

      <div class="container single-quote-section">

        <div class="text-block">

          <h2>Studio work and musical approach</h2>

          <p>
            Gabriel enjoys working with artists, producers, labels and musical directors who know what they want and are looking for refined acoustic guitar recordings, instrumental arrangements and productions with a professional studio sound, valuing every detail of the music.
          </p>

          <p>
            His contributions range from acoustic guitar sessions to instrumental production, arrangements, piano, bass, electric guitar, textures, editing and musical direction. In some projects, he also works as a mixing and mastering engineer.
          </p>

          <p>
            The goal is not only to make music. Gabriel thinks carefully about each professional involved, each person’s well-being and the relationships behind the work. He carefully chooses musicians who, besides being talented, will also be impacted by the project.
          </p>

          <blockquote class="artist-quote artist-quote-with-avatar">
            <p>
              “My greatest passion in music is producing an instrumental capable of creating such a rich conversation between instrument and voice that it becomes impossible not to be moved by the message, giving the music production a strong and memorable identity in the heart of the listener — where everyone, from everyday listeners to the greatest instrumentalists, singers, arrangers and audio engineers, can feel the music with the same depth that I feel it.”
            </p>

            <footer class="quote-author">
              <span>— Gabriel Soares</span>

              <span class="quote-author-avatar">
                <img
                  src="/images/about/gabriel-quote-avatar.jpg"
                  alt="Gabriel Soares"
                  loading="lazy"
                  decoding="async"
                />
              </span>
            </footer>
          </blockquote>

        </div>

      </div>

    </section>

    <section class="content-section dark">

      <div class="container split-section">

        <div class="text-block">

          <h2>Main recognition</h2>

          <p>
            Gabriel is a Latin GRAMMY® nominated music producer and appears at #840 in the worldwide guitarist ranking, according to public MUSO AI data.
          </p>

          <p>
            These recognitions are connected to his verified credits, released recordings, streaming data and his work as a music producer, studio acoustic guitarist and multi-instrumentalist.
          </p>

        </div>

        <div class="recognition-gallery single-recognition" aria-label="Latin GRAMMY recognition">

          {aboutImages.recognition.map((image) => (
            <figure class="recognition-image">
              <img
                src={image}
                alt="Latin GRAMMY recognition connected to Gabriel Soares credits"
              />
            </figure>
          ))}

        </div>

      </div>

    </section>

    <section
      class="faq-section faq-photo-section"
      style={`--faq-bg:url(${aboutImages.faq});`}
    >

      <div class="container faq-photo-content">

        <p class="eyebrow">SEARCH INFORMATION</p>

        <h2>Frequently searched questions</h2>

        <div class="faq">

          <article>
            <h3>Does Gabriel only work with productions in Brazil?</h3>

            <p>
              No. Gabriel works with remote acoustic guitar recordings, music production and live projects worldwide. Get in touch and explain how Gabriel can help you.
            </p>
          </article>

          <article>
            <h3>How can I hire Gabriel to record or produce?</h3>

            <p>
              The official contact channels for Gabriel are preferably email or WhatsApp. You can get in touch for acoustic guitar recordings, instrumental arrangements, music production, live projects or studio work.
            </p>
          </article>

          <article>
            <h3>Does Gabriel record any style or only gospel?</h3>

            <p>
              Gabriel has many well-known projects in gospel, Christian and worship music, but his style also connects naturally with folk, acoustic, singer-songwriter, pop, pop rock, country, worship and related sounds.
            </p>
          </article>

          <article>
            <h3>What instruments does Gabriel Soares record?</h3>

            <p>
              Gabriel records acoustic guitar, electric guitar, piano, bass, pads, overdubs, textures and instrumental production layers. His main signature instrument is the acoustic guitar, where his sound has been praised even by major names in the music industry.
            </p>
          </article>

        </div>

      </div>

    </section>

  </main>

  <Contact />

  <Footer />

</Layout>

<script is:inline>
if (
  window.location.hostname === "localhost" ||
  window.location.hostname === "127.0.0.1" ||
  new URLSearchParams(window.location.search).has("editphotos")
) {
  const editablePhotos = document.querySelectorAll(
    ".image-card img, .card-image img, .collage-photo img, .recognition-image img"
  );

  const tool = document.createElement("div");

  tool.innerHTML = `
    <button id="aboutPhotoToolToggle" style="
      position:fixed;
      right:18px;
      bottom:18px;
      width:46px;
      height:46px;
      z-index:100000;
      border:none;
      border-radius:999px;
      background:rgba(8,8,8,.92);
      color:white;
      border:1px solid rgba(255,255,255,.18);
      box-shadow:0 16px 50px rgba(0,0,0,.45);
      backdrop-filter:blur(16px);
      -webkit-backdrop-filter:blur(16px);
      cursor:pointer;
      font-size:1.15rem;
      line-height:1;
    ">▲</button>

    <div id="aboutPhotoToolPanel" style="
      position:fixed;
      right:18px;
      bottom:74px;
      width:min(430px, calc(100vw - 36px));
      max-height:52vh;
      z-index:99999;
      background:rgba(8,8,8,.94);
      color:white;
      border:1px solid rgba(255,255,255,.16);
      border-radius:18px;
      box-shadow:0 24px 90px rgba(0,0,0,.55);
      backdrop-filter:blur(18px);
      -webkit-backdrop-filter:blur(18px);
      font-family:Inter, sans-serif;
      overflow:hidden;
      display:none;
    ">
      <div style="
        padding:14px 16px;
        border-bottom:1px solid rgba(255,255,255,.1);
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:12px;
      ">
        <strong style="font-size:.86rem;">About Photo Position Tool</strong>
        <button id="aboutPhotoToolCopy" style="
          border:none;
          border-radius:999px;
          padding:8px 12px;
          background:white;
          color:black;
          font-size:.75rem;
          font-weight:700;
          cursor:pointer;
        ">Copy CSS</button>
      </div>

      <p style="
        padding:12px 16px 0;
        color:#bdbdbd;
        font-size:.74rem;
        line-height:1.55;
      ">
        With the tool open, drag the photo. Use the mouse wheel over it to zoom. Then copy the CSS below and paste it into the file.
      </p>

      <textarea id="aboutPhotoToolOutput" readonly style="
        width:100%;
        height:260px;
        margin-top:10px;
        padding:14px 16px;
        background:rgba(255,255,255,.045);
        color:#f0d7a3;
        border:none;
        outline:none;
        resize:none;
        font-family:monospace;
        font-size:.72rem;
        line-height:1.55;
      "></textarea>

      <div style="
        padding:10px 16px 14px;
        display:flex;
        gap:8px;
        justify-content:space-between;
      ">
        <button id="aboutPhotoToolReset" style="
          border:1px solid rgba(255,255,255,.16);
          border-radius:999px;
          padding:8px 12px;
          background:transparent;
          color:white;
          font-size:.75rem;
          cursor:pointer;
        ">Reset adjustments</button>

        <span id="aboutPhotoToolStatus" style="
          color:#9f9f9f;
          font-size:.72rem;
          align-self:center;
        ">Tool closed</span>
      </div>
    </div>
  `;

  document.body.appendChild(tool);

  const toggleButton = document.querySelector("#aboutPhotoToolToggle");
  const panel = document.querySelector("#aboutPhotoToolPanel");
  const output = document.querySelector("#aboutPhotoToolOutput");
  const copyButton = document.querySelector("#aboutPhotoToolCopy");
  const resetButton = document.querySelector("#aboutPhotoToolReset");
  const status = document.querySelector("#aboutPhotoToolStatus");

  const photoState = new Map();

  let photoToolEnabled = false;

  const setPhotosCursor = () => {
    editablePhotos.forEach((photo) => {
      photo.style.cursor = photoToolEnabled ? "grab" : "";
      photo.style.userSelect = photoToolEnabled ? "none" : "";
      photo.style.touchAction = photoToolEnabled ? "none" : "";
    });
  };

  toggleButton?.addEventListener("click", () => {
    if (!panel) return;

    photoToolEnabled = !photoToolEnabled;

    panel.style.display = photoToolEnabled ? "block" : "none";
    toggleButton.textContent = photoToolEnabled ? "▼" : "▲";

    setPhotosCursor();

    if (status) {
      status.textContent = photoToolEnabled ? "Tool open" : "Tool closed";
    }
  });

  const getPhotoInfo = (photo) => {
    if (photo.closest(".image-card.large")) {
      return {
        name: "who",
        selector: ".image-card.large img"
      };
    }

    const cardImage = photo.closest(".card-image");

    if (cardImage) {
      const article = cardImage.closest(".info-grid article");
      const articles = Array.from(document.querySelectorAll(".info-grid article"));
      const index = articles.indexOf(article) + 1;

      return {
        name: `info-${index}`,
        selector: `.info-grid article:nth-child(${index}) .card-image img`
      };
    }

    const recognitionImage = photo.closest(".recognition-image");

    if (recognitionImage) {
      const recognitionItems = Array.from(document.querySelectorAll(".recognition-image"));
      const index = recognitionItems.indexOf(recognitionImage) + 1;

      return {
        name: index === 1 ? "latin-grammy" : "recognition",
        selector: `.recognition-gallery .recognition-image:nth-child(${index}) img`
      };
    }

    return {
      name: "about-photo",
      selector: ".about-page img"
    };
  };

  const getStorageKey = (photo) => {
    return `about-photo-${getPhotoInfo(photo).name}`;
  };

  const parseInitialTransform = (photo) => {
    const computedStyle = window.getComputedStyle(photo);
    const transform = computedStyle.transform;

    if (!transform || transform === "none") {
      return {
        x: 0,
        y: 0,
        scale: 1,
      };
    }

    const matrix = new DOMMatrixReadOnly(transform);

    return {
      x: Math.round(matrix.m41 || 0),
      y: Math.round(matrix.m42 || 0),
      scale: Number((matrix.a || 1).toFixed(2)),
    };
  };

  const applyTransform = (photo, state) => {
    photo.style.transform =
      `translateX(${state.x}px) translateY(${state.y}px) scale(${state.scale})`;
  };

  const saveTransform = (photo, state) => {
    localStorage.setItem(getStorageKey(photo), JSON.stringify(state));
  };

  const updateOutput = () => {
    const blocks = [];

    editablePhotos.forEach((photo) => {
      const state = photoState.get(photo);
      const info = getPhotoInfo(photo);

      if (!state || !info.selector) return;

      blocks.push(`${info.selector}{
  transform:translateX(${state.x}px) translateY(${state.y}px) scale(${state.scale});
}`);
    });

    if (!output) return;

    output.value = blocks.join("\n\n");
  };

  editablePhotos.forEach((photo) => {
    const initial = parseInitialTransform(photo);
    const saved = localStorage.getItem(getStorageKey(photo));
    const parsedSaved = saved ? JSON.parse(saved) : null;

    const state = {
      x: parsedSaved?.x ?? initial.x,
      y: parsedSaved?.y ?? initial.y,
      scale: parsedSaved?.scale ?? initial.scale,
    };

    photoState.set(photo, state);
    applyTransform(photo, state);
  });

  setPhotosCursor();
  updateOutput();
}
</script>

<style>
.about-page{
  background:#070707;
  color:white;
}

.container{
  max-width:1200px;
  margin:auto;
  padding:0 6%;
}

.narrow{
  max-width:900px;
}

.hero-about{
  min-height:70vh;
  display:flex;
  align-items:center;
  padding:160px 0 100px;
  background:
    radial-gradient(circle at 20% 20%, rgba(210,176,120,.18), transparent 34%),
    linear-gradient(180deg, #050505, #090909);
}

.eyebrow{
  color:var(--gold);
  letter-spacing:6px;
  font-size:.78rem;
  margin-bottom:20px;
}

h1{
  font-size:clamp(4rem, 9vw, 8rem);
  line-height:.9;
  letter-spacing:-4px;
  margin-bottom:28px;
}

.lead{
  max-width:800px;
  color:rgba(255,255,255,.72);
  font-size:1.25rem;
  line-height:1.75;
}

.content-section{
  padding:100px 0;
  background:#090909;
}

.content-section.dark{
  background:#050505;
}

.split-section{
  display:grid;
  grid-template-columns:minmax(0, 1.1fr) minmax(340px, .9fr);
  gap:64px;
  align-items:center;
}

.text-block{
  max-width:720px;
}

h2{
  font-size:clamp(2.4rem, 5vw, 4rem);
  line-height:1.05;
  margin-bottom:30px;
  letter-spacing:-1.5px;
}

p{
  color:rgba(255,255,255,.68);
  font-size:1rem;
  line-height:1.85;
  margin-bottom:22px;
}

strong{
  color:white;
}

.image-card{
  position:relative;
  overflow:hidden;
  border-radius:34px;
  background:#151515;
  border:1px solid rgba(255,255,255,.09);
  box-shadow:
    0 30px 90px rgba(0,0,0,.34),
    inset 0 1px 0 rgba(255,255,255,.055);
}

.image-card::after,
.card-image::after,
.recognition-image::after{
  content:"";
  position:absolute;
  inset:0;
  background:
    linear-gradient(
      180deg,
      rgba(0,0,0,.02),
      rgba(0,0,0,.24)
    );
  pointer-events:none;
}

.image-card.large{
  aspect-ratio:4 / 5;
}

.image-card img,
.card-image img,
.recognition-image img{
  width:100%;
  height:100%;
  display:block;
  object-fit:cover;
}

.card-image img{
  object-fit:contain;
  background:#090909;
}

.info-grid{
  display:grid;
  grid-template-columns:repeat(3, 1fr);
  gap:26px;
}

.info-grid article{
  min-height:440px;
  padding:22px;
  border-radius:30px;
  background:
    linear-gradient(
      145deg,
      rgba(255,255,255,.07),
      rgba(255,255,255,.018)
    );
  border:1px solid rgba(255,255,255,.08);
  box-shadow:
    0 24px 70px rgba(0,0,0,.22),
    inset 0 1px 0 rgba(255,255,255,.055);
}

.card-image{
  position:relative;
  overflow:hidden;
  height:190px;
  margin-bottom:26px;
  border-radius:22px;
  background:#090909;
  border:1px solid rgba(255,255,255,.075);
}

.info-grid h3{
  font-size:1.7rem;
  margin-bottom:18px;
}

.info-grid p{
  margin-bottom:0;
}

.artist-quote{
  margin:34px 0 0;
  padding:24px 26px;
  border-radius:24px;
  background:
    linear-gradient(
      145deg,
      rgba(210,176,120,.12),
      rgba(255,255,255,.035)
    );
  border:1px solid rgba(210,176,120,.24);
  box-shadow:
    0 20px 70px rgba(0,0,0,.25),
    inset 0 1px 0 rgba(255,255,255,.07);
}

.artist-quote p{
  margin-bottom:14px;
  color:rgba(255,255,255,.82);
  font-size:1.02rem;
  line-height:1.85;
}

.artist-quote footer{
  color:#f0d7a3;
  font-size:.78rem;
  letter-spacing:2px;
  text-transform:uppercase;
}

.recognition-gallery{
  display:grid;
  gap:18px;
}

.recognition-gallery.single-recognition{
  max-width:520px;
  width:100%;
}

.recognition-image{
  position:relative;
  overflow:hidden;
  aspect-ratio:3 / 4;
  border-radius:28px;
  background:#151515;
  border:1px solid rgba(255,255,255,.09);
  box-shadow:0 28px 80px rgba(0,0,0,.28);
  display:flex;
  align-items:center;
  justify-content:center;
  padding:14px;
}

.recognition-image img{
  width:100%;
  height:100%;
  display:block;
  object-fit:contain;
  object-position:center;
}

.faq-section{
  position:relative;
  overflow:hidden;
  min-height:900px;
  padding:110px 0;
  background:#050505;
  display:flex;
  align-items:center;
}

.faq-photo-section{
  background-image:
    linear-gradient(
      90deg,
      rgba(0,0,0,.90) 0%,
      rgba(0,0,0,.78) 28%,
      rgba(0,0,0,.42) 52%,
      rgba(0,0,0,.12) 78%,
      rgba(0,0,0,.28) 100%
    ),
    var(--faq-bg);
  background-size:cover;
  background-position:center center;
  background-repeat:no-repeat;
}

.faq-photo-content{
  position:relative;
  z-index:2;
  width:min(760px, 54vw);
  max-width:760px;
  margin-left:clamp(48px, 4.5vw, 82px);
  margin-right:auto;
}

.faq-photo-content .eyebrow{
  text-shadow:0 4px 28px rgba(0,0,0,.85);
}

.faq-photo-content h2{
  max-width:760px;
  margin-bottom:26px;
  text-shadow:0 8px 38px rgba(0,0,0,.85);
}

.faq{
  display:grid;
