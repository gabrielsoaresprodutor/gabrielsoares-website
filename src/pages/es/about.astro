---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import Contact from "../../components/Contact.astro";

const siteUrl = "https://gabrielsoares.art.br";

const pageTitle = "Sobre Gabriel Soares | Productor Musical, Guitarrista Acústico de Estudio & Multiinstrumentista";

const pageDescription =
  "Perfil oficial de Gabriel Soares, productor musical brasileño, guitarrista acústico de estudio, arreglista y multiinstrumentista conocido por producción instrumental, grabaciones refinadas de guitarra acústica, proyectos en vivo, crédito como productor en un álbum nominado al Latin GRAMMY® y reconocimiento en MUSO AI.";

const aboutImages = {
  who: "/images/about/who-gabriel.jpg",
  production: "/images/about/music-production.jpg",
  live: "/images/about/live-projects.jpg",
  guitar: "/images/about/acoustic-guitar.jpg",
  faq: "/images/about/faq-stage.png",
  artists: [
    "/images/about/artist-1.jpg"
  ],
  recognition: [
    "/images/about/latin-grammy.jpg"
  ]
};

const profileSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "@id": `${siteUrl}/es/about#profile`,
  url: `${siteUrl}/es/about`,
  name: "Sobre Gabriel Soares",
  description: pageDescription,
  inLanguage: "es",
  mainEntity: {
    "@type": "Person",
    "@id": `${siteUrl}/#person`,
    name: "Gabriel Soares",
    url: siteUrl,
    jobTitle: [
      "Productor Musical",
      "Guitarrista Acústico de Estudio",
      "Arreglista",
      "Multiinstrumentista"
    ],
    description:
      "Gabriel Soares es un productor musical brasileño, guitarrista acústico de estudio, arreglista y multiinstrumentista conocido por producción instrumental, grabaciones refinadas de guitarra acústica, proyectos en vivo, créditos verificados, un crédito como producer en un álbum nominado al Latin GRAMMY® y reconocimiento como guitarrista en MUSO AI.",
    knowsAbout: [
      "Guitarra Acústica de Estudio",
      "Producción Musical",
      "Producción Musical en Vivo",
      "Grabación en Vivo",
      "Arreglo",
      "Producción Instrumental",
      "Grabación de Guitarra Acústica",
      "Grabación",
      "Instrumentación",
      "Música Cristiana",
      "Gospel",
      "Worship",
      "Créditos Musicales"
    ],
    sameAs: [
      "https://www.instagram.com/gabrielsoaresprodutor/",
      "https://www.youtube.com/@gabrielsoaresprodutor",
      "https://open.spotify.com/intl-pt/artist/4llhbsPozmyRXlJWNmAVHb"
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": `${siteUrl}/es/about#faq`,
  mainEntity: [
    {
      "@type": "Question",
      name: "¿Gabriel Soares trabaja solo con producciones de Brasil?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "No. Gabriel Soares trabaja con grabaciones remotas de guitarra acústica, producción musical y proyectos en vivo para artistas, productores, sellos y directores musicales en todo el mundo. Los canales oficiales de contacto son email y WhatsApp."
      }
    },
    {
      "@type": "Question",
      name: "¿Cómo puedo contratar a Gabriel para grabar o producir?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "La forma oficial de contactar a Gabriel Soares para grabaciones de guitarra acústica, arreglos instrumentales, producción musical y proyectos en vivo es preferiblemente por email o WhatsApp."
      }
    },
    {
      "@type": "Question",
      name: "¿Gabriel graba cualquier estilo o solamente gospel?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "Gabriel Soares tiene muchos proyectos conocidos en gospel, música cristiana y worship, pero también trabaja naturalmente con folk, acústico, singer-songwriter, pop, pop rock, country, worship y estilos relacionados. Puedes entrar en contacto y explicar lo que necesitas."
      }
    },
    {
      "@type": "Question",
      name: "¿Qué instrumentos graba Gabriel Soares?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "Gabriel Soares graba guitarra acústica, guitarra eléctrica, piano, bajo, pads, overdubs, texturas y capas de producción instrumental. Su principal instrumento de identidad es la guitarra acústica, donde su sonido ha sido elogiado incluso por grandes nombres de la industria musical."
      }
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>

  <script type="application/ld+json" set:html={JSON.stringify(profileSchema)} />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <Navbar />

  <main class="about-page">

    <section class="content-section">

      <div class="container split-section">

        <div class="text-block">

          <h2>¿Quién es Gabriel Soares?</h2>

          <p>
            Gabriel Soares es un productor musical brasileño, guitarrista acústico de estudio, arreglista y multiinstrumentista conocido por producción instrumental refinada y grabaciones de guitarra acústica.
          </p>

          <p>
            Su trabajo une sensibilidad, precisión y buen gusto musical, creando arreglos, partes fingerpicked, texturas acústicas y capas de producción que ayudan a que cada canción suene emocional, intencional y profesionalmente terminada.
          </p>

          <p>
            Sus créditos incluyen trabajos conectados a <strong>Vocal Livre</strong>, <strong>Pedro Valença</strong>, <strong>Arautos do Rei</strong>, <strong>Devoted Vocal</strong>, <strong>Novo Tom</strong>, <strong>Adoradores 5</strong>, <strong>Gabro</strong> y otros artistas.
          </p>

        </div>

        <figure class="image-card large">
          <img src={aboutImages.who} alt="Gabriel Soares en estudio y trabajo con guitarra acústica" />
        </figure>

      </div>

    </section>

    <section class="content-section dark">

      <div class="container">

        <div class="info-grid">

          <article>
            <figure class="card-image">
              <img src={aboutImages.live} alt="Producción musical en vivo y proyecto de grabación en vivo" />
            </figure>

            <h3>Proyectos En Vivo</h3>

            <p>
              Gabriel ya ha producido y grabado diversos proyectos en vivo, tanto como productor musical como músico instrumentista, trabajando en producciones audiovisuales, live sessions y grabaciones en vivo que requieren dirección musical, sensibilidad y consistencia de estudio.
            </p>
          </article>

          <article>
            <figure class="card-image">
              <img src={aboutImages.production} alt="Producción instrumental y sesión de estudio" />
            </figure>

            <h3>Producción Musical</h3>

            <p>
              Gabriel es especialmente conocido por su trabajo de producción instrumental, creando arreglos que hacen que los instrumentos conversen entre sí, construyendo escenarios, texturas y capas musicales que aportan profundidad, emoción y un sonido profesional a cada proyecto.
            </p>
          </article>

          <article>
            <figure class="card-image">
              <img src={aboutImages.guitar} alt="Grabación de guitarra acústica por Gabriel Soares" />
            </figure>

            <h3>Guitarra Acústica</h3>

            <p>
              Su trabajo con guitarra acústica se ha convertido en una de sus principales firmas, con fingerpicking refinado y una interpretación cuidadosamente construida, bien posicionada y creativa, desde canciones sensibles hasta partes con mucho punch sin perder riqueza. Su sonido de guitarra acústica se volvió una identidad musical marcada en cada grabación y proyecto en el que participa; muchos reconocen la guitarra de Gabriel Soares (Jhonny) al escuchar apenas unos segundos.
            </p>
          </article>

        </div>

      </div>

    </section>

    <section class="content-section">

      <div class="container split-section reverse">

        <div class="text-block">

          <h2>Trabajo de estudio y enfoque musical</h2>

          <p>
            Gabriel disfruta trabajar con artistas, productores, sellos y directores musicales que saben lo que quieren y buscan grabaciones refinadas de guitarra acústica, arreglos instrumentales y producciones con sonido profesional de estudio, valorando cada detalle de la música.
          </p>

          <p>
            Sus contribuciones van desde sesiones de guitarra acústica hasta producción instrumental, arreglos, piano, bajo, guitarra eléctrica, texturas, edición y dirección musical. En algunos proyectos, también trabaja como ingeniero de mezcla y masterización.
          </p>

          <p>
            El objetivo no es solo hacer música. Gabriel piensa cuidadosamente en cada profesional involucrado, en el bienestar de cada persona y en las relaciones de trabajo detrás del proyecto. Elige con cuidado músicos que, además de talentosos, también serán impactados por el proyecto.
          </p>

          <blockquote class="artist-quote">
            <p>
              “Mi mayor pasión en la música es producir un instrumental capaz de promover una conversación tan rica entre instrumento y voz que sea imposible no emocionarse con el mensaje, dando a la producción musical una identidad fuerte y memorable en el corazón de quien escucha — donde todos, desde los oyentes más simples hasta los mayores instrumentistas, cantantes, arreglistas e ingenieros de audio, puedan sentir la música con la misma profundidad con la que yo la siento.”
            </p>
            <footer>— Gabriel Soares, en sus propias palabras</footer>
          </blockquote>

        </div>

        <div class="artist-collage single-artist-photo" aria-label="Gabriel Soares con artista y colaborador">

          <figure class="collage-photo photo-1">
            <img src={aboutImages.artists[0]} alt="Gabriel Soares con artista o colaborador" />
          </figure>

        </div>

      </div>

    </section>

    <section class="content-section dark">

      <div class="container split-section">

        <div class="text-block">

          <h2>Principales reconocimientos</h2>

          <p>
            Gabriel es un productor musical nominado al Latin GRAMMY® y aparece en la posición #840 del ranking mundial de guitarristas, según datos públicos de MUSO AI.
          </p>

          <p>
            Estos reconocimientos se conectan con sus créditos verificados, grabaciones lanzadas, datos de streaming y su trabajo como productor musical, guitarrista acústico de estudio y multiinstrumentista.
          </p>

        </div>

        <div class="recognition-gallery single-recognition" aria-label="Reconocimiento Latin GRAMMY">

          {aboutImages.recognition.map((image) => (
            <figure class="recognition-image">
              <img
                src={image}
                alt="Reconocimiento Latin GRAMMY conectado a los créditos de Gabriel Soares"
              />
            </figure>
          ))}

        </div>

      </div>

    </section>

    <section
      class="faq-section faq-photo-section"
      style={`--faq-bg:url(${aboutImages.faq});`}
    >

      <div class="container faq-photo-content">

        <p class="eyebrow">INFORMACIÓN DE BÚSQUEDA</p>

        <h2>Preguntas buscadas con frecuencia</h2>

        <div class="faq">

          <article>
            <h3>¿Gabriel atiende solo producciones de Brasil?</h3>

            <p>
              No. Gabriel atiende grabaciones remotas de guitarra acústica, producción musical y proyectos en vivo en todo el mundo. Ponte en contacto y explica cómo Gabriel puede ayudarte.
            </p>
          </article>

          <article>
            <h3>¿Cómo puedo contratar a Gabriel para grabar o producir?</h3>

            <p>
              El medio oficial de contacto con Gabriel es, preferiblemente, por email o WhatsApp. Puedes entrar en contacto para grabaciones de guitarra acústica, arreglos instrumentales, producción musical, proyectos en vivo o trabajos de estudio.
            </p>
          </article>

          <article>
            <h3>¿Gabriel graba cualquier estilo o solamente gospel?</h3>

            <p>
              Gabriel tiene muchos proyectos conocidos en gospel, música cristiana y worship, pero su estilo también conversa con folk, acústico, singer-songwriter, pop, pop rock, country, worship y sonoridades cercanas.
            </p>
          </article>

          <article>
            <h3>¿Qué instrumentos graba Gabriel Soares?</h3>

            <p>
              Gabriel graba guitarra acústica, guitarra eléctrica, piano, bajo, pads, overdubs, texturas y capas de producción instrumental. Su principal instrumento de identidad es la guitarra acústica, donde su sonido ha sido elogiado incluso por grandes nombres de la industria musical.
            </p>
          </article>

        </div>

      </div>

    </section>

  </main>

  <Contact />

  <Footer />

</Layout>

<script is:inline>
if (
  window.location.hostname === "localhost" ||
  window.location.hostname === "127.0.0.1" ||
  new URLSearchParams(window.location.search).has("editphotos")
) {
  const editablePhotos = document.querySelectorAll(
    ".image-card img, .card-image img, .collage-photo img, .recognition-image img"
  );

  const tool = document.createElement("div");

  tool.innerHTML = `
    <button id="aboutPhotoToolToggle" style="
      position:fixed;
      right:18px;
      bottom:18px;
      width:46px;
      height:46px;
      z-index:100000;
      border:none;
      border-radius:999px;
      background:rgba(8,8,8,.92);
      color:white;
      border:1px solid rgba(255,255,255,.18);
      box-shadow:0 16px 50px rgba(0,0,0,.45);
      backdrop-filter:blur(16px);
      -webkit-backdrop-filter:blur(16px);
      cursor:pointer;
      font-size:1.15rem;
      line-height:1;
    ">▲</button>

    <div id="aboutPhotoToolPanel" style="
      position:fixed;
      right:18px;
      bottom:74px;
      width:min(430px, calc(100vw - 36px));
      max-height:52vh;
      z-index:99999;
      background:rgba(8,8,8,.94);
      color:white;
      border:1px solid rgba(255,255,255,.16);
      border-radius:18px;
      box-shadow:0 24px 90px rgba(0,0,0,.55);
      backdrop-filter:blur(18px);
      -webkit-backdrop-filter:blur(18px);
      font-family:Inter, sans-serif;
      overflow:hidden;
      display:none;
    ">
      <div style="
        padding:14px 16px;
        border-bottom:1px solid rgba(255,255,255,.1);
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:12px;
      ">
        <strong style="font-size:.86rem;">About Photo Position Tool</strong>
        <button id="aboutPhotoToolCopy" style="
          border:none;
          border-radius:999px;
          padding:8px 12px;
          background:white;
          color:black;
          font-size:.75rem;
          font-weight:700;
          cursor:pointer;
        ">Copiar CSS</button>
      </div>

      <p style="
        padding:12px 16px 0;
        color:#bdbdbd;
        font-size:.74rem;
        line-height:1.55;
      ">
        Com a ferramenta aberta, arraste a foto. Use o scroll em cima dela para zoom. Depois copie o CSS abaixo e cole no arquivo.
      </p>

      <textarea id="aboutPhotoToolOutput" readonly style="
        width:100%;
        height:260px;
        margin-top:10px;
        padding:14px 16px;
        background:rgba(255,255,255,.045);
        color:#f0d7a3;
        border:none;
        outline:none;
        resize:none;
        font-family:monospace;
        font-size:.72rem;
        line-height:1.55;
      "></textarea>

      <div style="
        padding:10px 16px 14px;
        display:flex;
        gap:8px;
        justify-content:space-between;
      ">
        <button id="aboutPhotoToolReset" style="
          border:1px solid rgba(255,255,255,.16);
          border-radius:999px;
          padding:8px 12px;
          background:transparent;
          color:white;
          font-size:.75rem;
          cursor:pointer;
        ">Resetar ajustes</button>

        <span id="aboutPhotoToolStatus" style="
          color:#9f9f9f;
          font-size:.72rem;
          align-self:center;
        ">Tool closed</span>
      </div>
    </div>
  `;

  document.body.appendChild(tool);

  const toggleButton = document.querySelector("#aboutPhotoToolToggle");
  const panel = document.querySelector("#aboutPhotoToolPanel");
  const output = document.querySelector("#aboutPhotoToolOutput");
  const copyButton = document.querySelector("#aboutPhotoToolCopy");
  const resetButton = document.querySelector("#aboutPhotoToolReset");
  const status = document.querySelector("#aboutPhotoToolStatus");

  const photoState = new Map();

  let photoToolEnabled = false;

  const setPhotosCursor = () => {
    editablePhotos.forEach((photo) => {
      photo.style.cursor = photoToolEnabled ? "grab" : "";
      photo.style.userSelect = photoToolEnabled ? "none" : "";
      photo.style.touchAction = photoToolEnabled ? "none" : "";
    });
  };

  toggleButton?.addEventListener("click", () => {
    if (!panel) return;

    photoToolEnabled = !photoToolEnabled;

    panel.style.display = photoToolEnabled ? "block" : "none";
    toggleButton.textContent = photoToolEnabled ? "▼" : "▲";

    setPhotosCursor();

    if (status) {
      status.textContent = photoToolEnabled ? "Tool open" : "Tool closed";
    }
  });

  const getPhotoInfo = (photo) => {
    if (photo.closest(".image-card.large")) {
      return {
        name: "who",
        selector: ".image-card.large img"
      };
    }

    const cardImage = photo.closest(".card-image");

    if (cardImage) {
      const article = cardImage.closest(".info-grid article");
      const articles = Array.from(document.querySelectorAll(".info-grid article"));
      const index = articles.indexOf(article) + 1;

      return {
        name: `info-${index}`,
        selector: `.info-grid article:nth-child(${index}) .card-image img`
      };
    }

    const collagePhoto = photo.closest(".collage-photo");

    if (collagePhoto) {
      if (collagePhoto.classList.contains("photo-1")) {
        return {
          name: "artist-1",
          selector: ".collage-photo.photo-1 img"
        };
      }

      if (collagePhoto.classList.contains("photo-2")) {
        return {
          name: "artist-2",
          selector: ".collage-photo.photo-2 img"
        };
      }

      if (collagePhoto.classList.contains("photo-3")) {
        return {
          name: "artist-3",
          selector: ".collage-photo.photo-3 img"
        };
      }
    }

    const recognitionImage = photo.closest(".recognition-image");

    if (recognitionImage) {
      const recognitionItems = Array.from(document.querySelectorAll(".recognition-image"));
      const index = recognitionItems.indexOf(recognitionImage) + 1;

      return {
        name: index === 1 ? "latin-grammy" : "recognition",
        selector: `.recognition-gallery .recognition-image:nth-child(${index}) img`
      };
    }

    return {
      name: "about-photo",
      selector: ".about-page img"
    };
  };

  const getStorageKey = (photo) => {
    return `about-photo-${getPhotoInfo(photo).name}`;
  };

  const parseInitialTransform = (photo) => {
    const computedStyle = window.getComputedStyle(photo);
    const transform = computedStyle.transform;

    if (!transform || transform === "none") {
      return {
        x: 0,
        y: 0,
        scale: 1,
      };
    }

    const matrix = new DOMMatrixReadOnly(transform);

    return {
      x: Math.round(matrix.m41 || 0),
      y: Math.round(matrix.m42 || 0),
      scale: Number((matrix.a || 1).toFixed(2)),
    };
  };

  const applyTransform = (photo, state) => {
    photo.style.transform =
      `translateX(${state.x}px) translateY(${state.y}px) scale(${state.scale})`;
  };

  const saveTransform = (photo, state) => {
    localStorage.setItem(getStorageKey(photo), JSON.stringify(state));
  };

  const updateOutput = () => {
    const blocks = [];

    editablePhotos.forEach((photo) => {
      const state = photoState.get(photo);
      const info = getPhotoInfo(photo);

      if (!state || !info.selector) return;

      blocks.push(`${info.selector}{
  transform:translateX(${state.x}px) translateY(${state.y}px) scale(${state.scale});
}`);
    });

    if (!output) return;

    output.value = blocks.join("\n\n");
  };

  editablePhotos.forEach((photo) => {
    const initial = parseInitialTransform(photo);
    const saved = localStorage.getItem(getStorageKey(photo));
    const parsedSaved = saved ? JSON.parse(saved) : null;

    const state = {
      x: parsedSaved?.x ?? initial.x,
      y: parsedSaved?.y ?? initial.y,
      scale: parsedSaved?.scale ?? initial.scale,
    };

    photoState.set(photo, state);
    applyTransform(photo, state);

    let isDragging = false;
    let startX = 0;
    let startY = 0;

    photo.addEventListener("mousedown", (event) => {
      if (!photoToolEnabled) return;

      isDragging = true;
      startX = event.clientX - state.x;
      startY = event.clientY - state.y;

      photo.style.cursor = "grabbing";
      event.preventDefault();
    });

    window.addEventListener("mousemove", (event) => {
      if (!photoToolEnabled || !isDragging) return;

      state.x = Math.round(event.clientX - startX);
      state.y = Math.round(event.clientY - startY);

      applyTransform(photo, state);
      saveTransform(photo, state);
      updateOutput();
    });

    window.addEventListener("mouseup", () => {
      if (!isDragging) return;

      isDragging = false;

      if (photoToolEnabled) {
        photo.style.cursor = "grab";
      }

      saveTransform(photo, state);
      updateOutput();

      if (status) {
        status.textContent = `${getPhotoInfo(photo).name} salvo localmente`;
      }
    });

    photo.addEventListener("wheel", (event) => {
      if (!photoToolEnabled) return;

      event.preventDefault();

      if (event.deltaY < 0) {
        state.scale += 0.04;
      } else {
        state.scale -= 0.04;
      }

      state.scale = Number(Math.max(.7, Math.min(state.scale, 3)).toFixed(2));

      applyTransform(photo, state);
      saveTransform(photo, state);
      updateOutput();

      if (status) {
        status.textContent = `${getPhotoInfo(photo).name} zoom ${state.scale}`;
      }
    });
  });

  copyButton?.addEventListener("click", async () => {
    if (!output) return;

    await navigator.clipboard.writeText(output.value);

    if (status) {
      status.textContent = "CSS copiado";
    }
  });

  resetButton?.addEventListener("click", () => {
    editablePhotos.forEach((photo) => {
      localStorage.removeItem(getStorageKey(photo));
      photo.style.transform = "";
    });

    if (status) {
      status.textContent = "Ajustes apagados. Recarregue a página.";
    }
  });

  setPhotosCursor();
  updateOutput();
}
</script>

<style>
.about-page{
  background:#070707;
  color:white;
}

.container{
  max-width:1200px;
  margin:auto;
  padding:0 6%;
}

.narrow{
  max-width:900px;
}

.hero-about{
  min-height:70vh;
  display:flex;
  align-items:center;
  padding:160px 0 100px;
  background:
    radial-gradient(circle at 20% 20%, rgba(210,176,120,.18), transparent 34%),
    linear-gradient(180deg, #050505, #090909);
}

.eyebrow{
  color:var(--gold);
  letter-spacing:6px;
  font-size:.78rem;
  margin-bottom:20px;
}

h1{
  font-size:clamp(4rem, 9vw, 8rem);
  line-height:.9;
  letter-spacing:-4px;
  margin-bottom:28px;
}

.lead{
  max-width:800px;
  color:rgba(255,255,255,.72);
  font-size:1.25rem;
  line-height:1.75;
}

.content-section{
  padding:100px 0;
  background:#090909;
}

.content-section.dark{
  background:#050505;
}

.split-section{
  display:grid;
  grid-template-columns:minmax(0, 1.1fr) minmax(340px, .9fr);
  gap:64px;
  align-items:center;
}

.split-section.reverse{
  grid-template-columns:minmax(340px, .9fr) minmax(0, 1.1fr);
}

.split-section.reverse .text-block{
  order:2;
}

.split-section.reverse .artist-collage{
  order:1;
}

.text-block{
  max-width:720px;
}

h2{
  font-size:clamp(2.4rem, 5vw, 4rem);
  line-height:1.05;
  margin-bottom:30px;
  letter-spacing:-1.5px;
