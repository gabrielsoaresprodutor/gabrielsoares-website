const applyReplacements = (value: string, replacements: Replacement[]): string => {
  return [...replacements]
    .sort(([firstFrom], [secondFrom]) => secondFrom.length - firstFrom.length)
    .reduce((result: string, [from, to]: Replacement) => {
      return result.split(from).join(to);
    }, value);
};

const localizeText = (
  value: string | undefined,
  language: SiteLanguage
): string | undefined => {
  if (!value || language === "en") return value;

  return applyReplacements(value, textReplacements[language]);
};

const localizeDescription = (
  value: string | undefined,
  language: SiteLanguage
): string | undefined => {
  if (!value || language === "en") return value;

  return descriptionTranslations[language][value] ?? localizeText(value, language);
};

const localizeProject = (project: Project, language: SiteLanguage): Project => {
  const localizedHighlight = project.highlight
    ? localizeText(project.highlight, language)
    : undefined;

  const localizedDescription = project.description
    ? localizeDescription(project.description, language)
    : undefined;

  return {
    ...project,
    role: localizeText(project.role, language) ?? project.role,
    ...(localizedHighlight ? { highlight: localizedHighlight } : {}),
    ...(localizedDescription ? { description: localizedDescription } : {}),
    credits: project.credits.map((credit: string) =>
      localizeText(credit, language) ?? credit
    ),
  };
};

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project: rawProject } = Astro.props as { project: Project };
