  creditText: project.role,
  sameAs: [
    project.spotify,
    project.youtube
  ].filter(Boolean)
};
---

<Layout title={pageTitle} description={pageDescription}>

  <script type="application/ld+json" set:html={JSON.stringify(projectSchema)} />

  <Navbar />

  <main class="project">

    <a class="back" href={`${basePath}/work`}>
      <span>←</span>
      {t.back}
    </a>

    <section class="hero-project">

      <div class="cover">
        <img
          src={project.image.src}
          alt={`${project.artist} - ${project.title}`}
        />
      </div>

      <div class="content">

        <p class="eyebrow">{project.artist}</p>

        <h1>
          {project.slug === "alfredo" ? (
            <>O Senhor é o Meu<br />Pastor</>
          ) : project.slug === "fixa-teus-olhos" ? (
            <>Fixa Teus Olhos<br />em Mim</>
          ) : (
            project.title
          )}
        </h1>

        <p class="role">{project.role}</p>

        {project.highlight && (
          <div class="badge">
            <span class="badge-text">{project.highlight}</span>
          </div>
        )}

        {project.description && (
          <section class="block">
            <p class="label">{t.about}</p>

            <p class="text">{project.description}</p>
          </section>
        )}

        {project.credits && project.credits.length > 0 && (
          <section class="block">
            <p class="label">{t.contributions}</p>

            <div class="credits">
              {project.credits.map((credit: string) => (
                <span>{credit}</span>
              ))}
            </div>
          </section>
        )}

        {(project.spotify || project.youtube) && (
          <div class="listen-group">

            {project.spotify && (
              <a
                class="listen"
                href={project.spotify}
                target="_blank"
                rel="noopener noreferrer"
              >
                {t.listen}
              </a>
            )}

            {project.youtube && (
              <a
                class="listen secondary-listen"
                href={project.youtube}
                target="_blank"
                rel="noopener noreferrer"
              >
                {t.watch}
              </a>
            )}

          </div>
        )}

      </div>

    </section>

  </main>

  <Footer />

</Layout>

<style>
.project{
  background:#050505;
  color:white;
  min-height:100vh;
}

.back{
  position:fixed;
  top:92px;
  left:6%;
  z-index:999;
  display:flex;
  align-items:center;
  gap:10px;
  width:fit-content;
  background:rgba(255,255,255,.07);
  color:white;
  border:1px solid rgba(255,255,255,.14);
  border-radius:999px;
  padding:13px 20px;
  text-decoration:none;
  font:inherit;
  font-size:.9rem;
  font-weight:600;
  cursor:pointer;
  backdrop-filter:blur(16px);
  -webkit-backdrop-filter:blur(16px);
  transition:.3s;
}

.back span{
  display:inline-block;
  transition:.3s;
}

.back:hover{
  background:white;
  color:black;
  transform:translateY(-2px);
}

.back:hover span{
  transform:translateX(-4px);
}

.hero-project{
  min-height:100vh;
  display:grid;
  grid-template-columns:1fr .9fr;
  align-items:center;
  gap:80px;
  padding:150px 6% 120px;
}

.cover img{
  width:100%;
  border-radius:28px;
  object-fit:cover;
  box-shadow:0 40px 100px rgba(0,0,0,.45);
}

.content{
  max-width:650px;
}

.eyebrow{
  color:var(--gold);
  letter-spacing:8px;
  font-size:.78rem;
  margin-bottom:22px;
  text-transform:uppercase;
}

h1{
  font-size:5.4rem;
  line-height:.95;
  margin-bottom:28px;
}

.role{
  color:#d7d7d7;
  font-size:1.25rem;
  line-height:1.8;
  margin-bottom:28px;
}

.badge{
  display:inline-flex;
  align-items:center;
  width:fit-content;
  padding:12px 20px;
  border-radius:999px;
  background:rgba(210,176,120,.08);
  border:1px solid rgba(210,176,120,.22);
}

.badge-text{
  color:#f0d7a3;
  font-size:.92rem;
  font-weight:600;
  letter-spacing:.3px;
  line-height:1;
}

.block{
  margin-top:48px;
  padding-top:34px;
  border-top:1px solid rgba(255,255,255,.09);
}

.label{
  color:var(--gold);
  letter-spacing:4px;
  text-transform:uppercase;
  font-size:.72rem;
  margin-bottom:18px;
}

.text{
  color:#cfcfcf;
  font-size:1.05rem;
  line-height:1.9;
  max-width:560px;
}

.credits{
  display:flex;
  flex-wrap:wrap;
  gap:12px;
}

.credits span{
  padding:10px 15px;
  border-radius:999px;
  background:#121212;
  border:1px solid rgba(255,255,255,.08);
  color:#d9d9d9;
  font-size:.9rem;
}

.listen-group{
  display:flex;
  flex-wrap:wrap;
  gap:12px;
  margin-top:42px;
}

.listen{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:15px 24px;
  border-radius:999px;
  background:white;
  color:black;
  text-decoration:none;
  font-weight:700;
  transition:.3s;
}

.listen:hover{
  transform:translateY(-3px);
}

.secondary-listen{
  background:rgba(255,255,255,.06);
  color:white;
  border:1px solid rgba(255,255,255,.14);
}

.secondary-listen:hover{
  background:rgba(255,255,255,.12);
  color:white;
}

@media(max-width:900px){
  .hero-project{
    grid-template-columns:1fr;
    padding-top:170px;
    gap:46px;
  }

  h1{
    font-size:3.4rem;
  }

  .back{
    top:92px;
    left:6%;
  }
}

@media(max-width:700px){
  .hero-project{
    padding:155px 6% 90px;
  }

  .back{
    position:absolute;
    top:92px;
    left:6%;
    right:6%;
    width:auto;
    justify-content:center;
  }

  h1{
    font-size:3rem;
  }

  .role{
    font-size:1.05rem;
  }

  .listen-group{
    flex-direction:column;
  }

  .listen{
    width:100%;
  }
}
</style>
