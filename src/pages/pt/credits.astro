---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import Contact from "../../components/Contact.astro";
import { projects } from "../../data/projects";

const siteUrl = "https://gabrielsoares.art.br";

const pageTitle = "Cr\u00e9ditos de Gabriel Soares | Produ\u00e7\u00e3o Musical & Viol\u00e3o";

const pageDescription =
  "P\u00e1gina oficial de cr\u00e9ditos de Gabriel Soares, produtor musical brasileiro, violonista, arranjador e multi-instrumentista com cr\u00e9ditos em projetos de m\u00fasica crist\u00e3, gospel e worship.";


const projectTextReplacements: Record<string, string> = {
  "Music Production": "Produ\u00e7\u00e3o Musical",
  "music production": "produ\u00e7\u00e3o musical",
  "Producer": "Produtor",
  "producer": "produtor",
  "Production": "Produ\u00e7\u00e3o",
  "production": "produ\u00e7\u00e3o",
  "Acoustic Guitar": "Viol\u00e3o",
  "acoustic guitar": "viol\u00e3o",
  "Guitar": "Viol\u00e3o",
  "guitar": "viol\u00e3o",
  "Arrangements": "Arranjos",
  "arrangements": "arranjos",
  "Arrangement": "Arranjo",
  "arrangement": "arranjo",
  "Instrumental Production": "Produ\u00e7\u00e3o Instrumental",
  "instrumental production": "produ\u00e7\u00e3o instrumental",
  "Piano": "Piano",
  "Bass": "Baixo",
  "bass": "baixo",
  "Electric Guitar": "Guitarra",
  "electric guitar": "guitarra",
  "Pads": "Pads",
  "Instrumentation": "Instrumenta\u00e7\u00e3o",
  "instrumentation": "instrumenta\u00e7\u00e3o",
  "Editing": "Edi\u00e7\u00e3o",
  "editing": "edi\u00e7\u00e3o",
  "Recording": "Grava\u00e7\u00e3o",
  "recording": "grava\u00e7\u00e3o",
  "Recordings": "Grava\u00e7\u00f5es",
  "recordings": "grava\u00e7\u00f5es",
  "Live Recording": "Grava\u00e7\u00e3o ao Vivo",
  "live recording": "grava\u00e7\u00e3o ao vivo",
  "Live": "Ao Vivo",
  "live": "ao vivo",
  "Credits": "Cr\u00e9ditos",
  "credits": "cr\u00e9ditos",
  "Featured": "Destaque",
  "featured": "destaque",
  "Released": "Lan\u00e7ado",
  "released": "lan\u00e7ado",
  "Christian": "Crist\u00e3",
  "christian": "crist\u00e3",
  "Gospel": "Gospel",
  "worship": "worship",
  "Views": "Visualiza\u00e7\u00f5es",
  "views": "visualiza\u00e7\u00f5es",
  "Streams": "Streams",
  "streams": "streams",
  "Single": "Single",
  "single": "single",
  "Album": "\u00c1lbum",
  "album": "\u00e1lbum"
};

const localizeProjectText = (value?: string | null) => {
  if (!value) return "";

  let localizedValue = value;

  Object.entries(projectTextReplacements).forEach(([source, replacement]) => {
    localizedValue = localizedValue.replaceAll(source, replacement);
  });

  return localizedValue;
};

const localizedProjects = projects.map((project) => ({
  ...project,
  role: localizeProjectText(project.role),
  highlight: localizeProjectText(project.highlight),
  description: localizeProjectText(project.description),
  credits: project.credits.map((credit) => localizeProjectText(credit)),
}));

const creditsSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${siteUrl}/pt/credits#credits`,
  url: `${siteUrl}/pt/credits`,
  name: "Cr\u00e9ditos de Gabriel Soares",
  description: pageDescription,
  inLanguage: "pt-BR",
  about: {
    "@type": "Person",
    "@id": `${siteUrl}/#person`,
    name: "Gabriel Soares",
    url: siteUrl
  },
  mainEntity: {
    "@type": "ItemList",
    name: "Cr\u00e9ditos musicais selecionados de Gabriel Soares",
    itemListElement: localizedProjects.map((project, index) => ({
      "@type": "ListItem",
      position: index + 1,
      item: {
        "@type": "MusicRecording",
        name: `${project.artist} - ${project.title}`,
        byArtist: {
          "@type": "MusicGroup",
          name: project.artist
        },
        description: project.description,
        contributor: {
          "@type": "Person",
          "@id": `${siteUrl}/#person`,
          name: "Gabriel Soares"
        },
        image: `${siteUrl}${project.image.src}`
      }
    }))
  },
  hasPart: localizedProjects.map((project) => ({
    "@type": "CreativeWork",
    name: `${project.artist} - ${project.title}`,
    description: project.description,
    contributor: {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      name: "Gabriel Soares"
    }
  }))
};
---
<Layout title={pageTitle} description={pageDescription}>

  <script type="application/ld+json" set:html={JSON.stringify(creditsSchema)} />

  <Navbar />

  <main class="credits-page">

    <section class="credits-hero">

      <div class="container">

        <p class="eyebrow">CRÉDITOS OFICIAIS</p>

        <h1>Créditos Selecionados</h1>

        <p class="lead">
          Produção musical, violão, arranjos e gravações instrumentais de Gabriel Soares em projetos lançados de música cristã, gospel e worship.
        </p>

      </div>

    </section>

    <section class="credits-intro">

      <div class="container narrow">

        <h2>Créditos musicais de Gabriel Soares</h2>

        <p>
          Os créditos de Gabriel Soares incluem produção musical, gravações de violão, arranjos, piano, baixo, guitarra, pads, instrumentação e edição para artistas e projetos como <strong>Vocal Livre</strong>, <strong>Arautos do Rei</strong>, <strong>Pedro Valença</strong>, <strong>Devoted Vocal</strong>, <strong>Novo Tom</strong>, <strong>Adoradores 5</strong>, <strong>Gabro</strong> e outros projetos de música cristã.
        </p>

        <p>
          Seu trabalho inclui contribuições em <strong>Temporal</strong>, álbum do Vocal Livre indicado ao Latin GRAMMY®, além de projetos ao vivo, lançamentos acústicos, singles e gravações conectadas a milhões de streams e visualizações.
        </p>

        <p>
          Esta página reúne trabalhos lançados selecionados conectados a Gabriel Soares como produtor musical, violonista, arranjador, multi-instrumentista e colaborador de gravação.
        </p>

      </div>

    </section>

    <section class="credits-list">

      <div class="container">

        <div class="grid">

          {localizedProjects.map((project) => (

            <article class="credit-card">

              <div class="image-wrap">
                <img
                  src={project.image.src}
                  alt={`${project.artist} - ${project.title}`}
                  loading="lazy"
                />
              </div>

              <div class="content">

                <p class="artist">{project.artist}</p>

                <h3>
                  {project.slug === "alfredo" ? (
                    <>O Senhor é o Meu<br />Pastor</>
                  ) : project.slug === "fixa-teus-olhos" ? (
                    <>Fixa Teus Olhos<br />em Mim</>
                  ) : (
                    project.title
                  )}
                </h3>

                <p class="role">{project.role}</p>

                {project.highlight && (
                  <span class="highlight">{project.highlight}</span>
                )}

                <p class="description">{project.description}</p>

                <div class="credits">

                  {project.credits.map((credit) => (
                    <span>{credit}</span>
                  ))}

                </div>

              </div>

            </article>

          ))}

        </div>

      </div>

    </section>

  </main>

  <Contact />

  <Footer />

</Layout>

<style>
.credits-page{
  background:#070707;
  color:white;
}

.container{
  max-width:1200px;
  margin:auto;
  padding:0 6%;
}

.narrow{
  max-width:900px;
}

.credits-hero{
  min-height:68vh;
  display:flex;
  align-items:center;
  padding:160px 0 100px;
  background:
    radial-gradient(circle at 25% 20%, rgba(210,176,120,.18), transparent 34%),
    linear-gradient(180deg, #050505, #090909);
}

.eyebrow{
  color:var(--gold);
  letter-spacing:6px;
  font-size:.78rem;
  margin-bottom:20px;
}

h1{
  font-size:clamp(4rem, 9vw, 8rem);
  line-height:.9;
  letter-spacing:-4px;
  margin-bottom:28px;
}

.lead{
  max-width:760px;
  color:rgba(255,255,255,.72);
  font-size:1.25rem;
  line-height:1.75;
}

.credits-intro{
  padding:100px 0;
  background:#090909;
}

h2{
  font-size:clamp(2.4rem, 5vw, 4rem);
  line-height:1.05;
  margin-bottom:30px;
  letter-spacing:-1.5px;
}

p{
  color:rgba(255,255,255,.68);
  font-size:1rem;
  line-height:1.85;
  margin-bottom:22px;
}

strong{
  color:white;
}

.credits-list{
  padding:40px 0 120px;
  background:#090909;
}

.grid{
  display:grid;
  grid-template-columns:repeat(3, 1fr);
  gap:28px;
}

.credit-card{
  background:#141414;
  border:1px solid rgba(255,255,255,.08);
  border-radius:24px;
  overflow:hidden;
  display:flex;
  flex-direction:column;
  box-shadow:0 24px 70px rgba(0,0,0,.22);
  transition:.35s ease;
}

.credit-card:hover{
  transform:translateY(-6px);
  border-color:rgba(210,176,120,.3);
}

.image-wrap{
  overflow:hidden;
  background:#080808;
}

.image-wrap img{
  width:100%;
  aspect-ratio:1/1;
  object-fit:cover;
  display:block;
  transition:.5s ease;
}

.credit-card:hover .image-wrap img{
  transform:scale(1.04);
}

.content{
  padding:26px;
  display:flex;
  flex-direction:column;
  flex:1;
}

.artist{
  color:#aaa;
  letter-spacing:3px;
  font-size:.72rem;
  text-transform:uppercase;
  margin-bottom:10px;
}

h3{
  font-size:1.85rem;
  line-height:1.15;
  margin-bottom:12px;
}

.role{
  color:#c9c9c9;
  margin-bottom:16px;
}

.highlight{
  display:inline-block;
  width:fit-content;
  margin-bottom:18px;
  padding:8px 13px;
  border-radius:999px;
  border:1px solid rgba(210,176,120,.28);
  color:#f0d7a3;
  font-size:.75rem;
}

.description{
  color:rgba(255,255,255,.58);
  font-size:.9rem;
  line-height:1.65;
  margin-bottom:20px;
}

.credits{
  display:flex;
  flex-wrap:wrap;
  gap:8px;
  margin-top:auto;
}

.credits span{
  display:inline-flex;
  padding:7px 10px;
  border-radius:999px;
  background:rgba(255,255,255,.055);
  border:1px solid rgba(255,255,255,.075);
  color:rgba(255,255,255,.62);
  font-size:.72rem;
}

@media(max-width:1000px){
  .grid{
    grid-template-columns:repeat(2, 1fr);
  }
}

@media(max-width:700px){
  .credits-hero{
    min-height:auto;
    padding:140px 0 80px;
  }

  h1{
    letter-spacing:-2px;
  }

  .lead{
    font-size:1.05rem;
  }

  .credits-intro{
    padding:80px 0;
  }

  .credits-list{
    padding:20px 0 90px;
  }

  .grid{
    grid-template-columns:1fr;
  }

  h3{
    font-size:1.75rem;
  }
}
</style>
